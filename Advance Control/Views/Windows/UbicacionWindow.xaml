<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Advance_Control.Views.Windows.UbicacionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Título -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12" Spacing="4">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Crear Ubicación" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Busca una dirección o haz clic en el mapa para seleccionar la ubicación." />
        </StackPanel>

        <!-- Buscador -->
        <TextBox
            x:Name="MapSearchBox"
            Grid.Row="1"
            Margin="0,0,0,8"
            KeyDown="MapSearchBox_KeyDown"
            PlaceholderText="Buscar dirección... (Enter para buscar)" />

        <!-- Mapa -->
        <WebView2
            x:Name="MapWebView"
            Grid.Row="2"
            Margin="0,0,0,12" />

        <!-- Formulario -->
        <Border
            Grid.Row="3"
            Margin="0,0,0,12"
            Padding="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="8">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="NombreTextBox"
                        Grid.Column="0"
                        Header="Nombre *"
                        PlaceholderText="Nombre de la ubicación" />
                    <TextBox
                        x:Name="LatitudTextBox"
                        Grid.Column="1"
                        Header="Latitud"
                        IsReadOnly="True" />
                    <TextBox
                        x:Name="LongitudTextBox"
                        Grid.Column="2"
                        Header="Longitud"
                        IsReadOnly="True" />
                </Grid>
                <TextBox
                    x:Name="DireccionTextBox"
                    Header="Dirección"
                    IsReadOnly="True"
                    PlaceholderText="Se detecta automáticamente al hacer clic en el mapa" />

                <InfoBar
                    x:Name="StatusInfoBar"
                    IsClosable="False"
                    IsOpen="False"
                    Severity="Informational" />
            </StackPanel>
        </Border>

        <!-- Botones -->
        <StackPanel
            Grid.Row="4"
            HorizontalAlignment="Right"
            Orientation="Horizontal"
            Spacing="8">
            <Button Click="CancelarButton_Click" Content="Cancelar" />
            <Button
                x:Name="GuardarButton"
                Click="GuardarButton_Click"
                Content="Guardar"
                IsEnabled="False"
                Style="{StaticResource AccentButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
