<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Advance_Control.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Advance_Control"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Advance Control"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="8*" />
            <ColumnDefinition x:Name="NotificacionesColumn" Width="0" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid x:Name="TopBar" Grid.Row="0">
                <Grid Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <!--  Botón login/logout con PersonPicture  -->
                        <StackPanel
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="8">
                            <Button
                                x:Name="LogIn"
                                Width="36"
                                Height="36"
                                Padding="0"
                                VerticalAlignment="Center"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                Click="LoginButton_Click"
                                CornerRadius="5,0,5,0"
                                ToolTipService.ToolTip="Cuenta de usuario">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{ThemeResource AccentAAFillColorDisabled}" />
                                </Button.Resources>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="{Binding UserInitials}" />
                            </Button>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                Text="{Binding UserType}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Column="1">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="15"
                            FontWeight="Bold"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            Text="{Binding Title}" />
                    </Grid>

                    <Grid Grid.Column="2">
                        <Button
                            x:Name="ToggleNotificacionesButton"
                            Width="36"
                            Height="36"
                            Margin="0,0,5,0"
                            Padding="0"
                            HorizontalAlignment="Right"
                            Background="{Binding HasUnseenNotifications, Converter={StaticResource NotificationColorConverter}}"
                            Click="ToggleNotificaciones_Click"
                            CornerRadius="5,0,5,0"
                            ToolTipService.ToolTip="Notificaciones">
                            <FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Glyph="&#xEA8F;" />
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
            <Grid Grid.Row="1">
                <NavigationView
                    x:Name="nvSample"
                    IsBackButtonVisible="Collapsed"
                    IsBackEnabled="{Binding IsBackEnabled, Mode=OneWay}"
                    IsPaneOpen="False">
                    <NavigationView.MenuItems>
                        <NavigationViewItem
                            Background="{ThemeResource ControlElevationBorderBrush}"
                            Content="Inicio"
                            Tag="Inicio">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE80F;" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <!--  Grupo: Negocios  -->
                        <NavigationViewItem
                            Background="{ThemeResource ControlElevationBorderBrush}"
                            Content="Operaciones"
                            IsExpanded="True"
                            SelectsOnInvoked="False">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE822;" />
                            </NavigationViewItem.Icon>
                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem Content="Operaciones" Tag="Operaciones">
                                    <NavigationViewItem.Icon>
                                        <FontIcon Glyph="&#xE9F5;" />
                                    </NavigationViewItem.Icon>
                                </NavigationViewItem>
                                <!--
                                    NavigationViewItem
                                    Content="Asesoría" Icon="ContactInfo" Tag="Asesoria" /
                                -->
                                <NavigationViewItem
                                    Content="Mantenimiento"
                                    Icon="Repair"
                                    Tag="Mantenimiento" />
                                <NavigationViewItem Content="Levantamientos" Tag="Levantamientos">
                                    <NavigationViewItem.Icon>
                                        <FontIcon Glyph="&#xE8FF;" />
                                    </NavigationViewItem.Icon>
                                </NavigationViewItem>
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                        <!--  Grupo: Clientes  -->
                        <NavigationViewItem
                            Background="{ThemeResource ControlElevationBorderBrush}"
                            Content="Clientes"
                            IsExpanded="True">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE716;" />
                            </NavigationViewItem.Icon>
                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem Content="Clientes" Tag="Clientes">
                                    <NavigationViewItem.Icon>
                                        <FontIcon Glyph="&#xE902;" />
                                    </NavigationViewItem.Icon>
                                </NavigationViewItem>
                                <NavigationViewItem
                                    Content="Contactos"
                                    Icon="Contact"
                                    Tag="Contactos" />
                                <NavigationViewItem Content="Entidades" Tag="Entidades">
                                    <NavigationViewItem.Icon>
                                        <FontIcon Glyph="&#xE8C7;" />
                                    </NavigationViewItem.Icon>
                                </NavigationViewItem>
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                        <!--  Grupo: Catálogos  -->
                        <NavigationViewItem
                            Background="{ThemeResource ControlElevationBorderBrush}"
                            Content="Catálogos"
                            Icon="Library"
                            IsExpanded="True">

                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem
                                    Content="Equipos"
                                    Icon="AllApps"
                                    Tag="Equipos" />
                                <NavigationViewItem
                                    Content="Refacciones"
                                    Icon="Setting"
                                    Tag="Refacciones" />
                                <NavigationViewItem Content="Servicios" Tag="Servicios">
                                    <NavigationViewItem.Icon>
                                        <FontIcon Glyph="&#xEC7A;" />
                                    </NavigationViewItem.Icon>
                                </NavigationViewItem>
                                <NavigationViewItem
                                    Content="Proveedores"
                                    Icon="Contact"
                                    Tag="Proveedores" />
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                        <!--  Grupo: Ubicaciones  -->
                        <NavigationViewItem
                            Background="{ThemeResource ControlElevationBorderBrush}"
                            Content="Ubicaciones"
                            IsExpanded="True">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE913;" />
                            </NavigationViewItem.Icon>
                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem
                                    Content="Ubicaciones"
                                    Icon="MapPin"
                                    Tag="Ubicaciones" />
                                <NavigationViewItem
                                    Content="Áreas"
                                    Icon="Map"
                                    Tag="Areas" />
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                        <!--  Grupo: Financiero  -->
                        <NavigationViewItem
                            Background="{ThemeResource ControlElevationBorderBrush}"
                            Content="Financiero"
                            IsExpanded="True">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE825;" />
                            </NavigationViewItem.Icon>
                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem Content="Estado de Cuenta" Tag="EstadoCuenta">
                                    <NavigationViewItem.Icon>
                                        <FontIcon Glyph="&#xEAFC;" />
                                    </NavigationViewItem.Icon>
                                </NavigationViewItem>
                                <NavigationViewItem
                                    Content="Conciliación"
                                    Icon="Switch"
                                    Tag="Conciliacion" />
                                <NavigationViewItem
                                    Content="Facturas"
                                    Icon="Document"
                                    Tag="Facturas" />
                                <!--  ReportHacked  -->
                                <NavigationViewItem Content="Reporte Facturación" Tag="ReporteFinancieroFacturacion">
                                    <NavigationViewItem.Icon>
                                        <FontIcon Glyph="&#xE9F9;" />
                                    </NavigationViewItem.Icon>
                                </NavigationViewItem>
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                        <!--  Grupo: Correo  -->
                        <NavigationViewItem
                            Background="{ThemeResource ControlElevationBorderBrush}"
                            Content="Correo"
                            IsExpanded="True">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE715;" />
                            </NavigationViewItem.Icon>
                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem
                                    Content="Configuración"
                                    Icon="Setting"
                                    Tag="Correo" />
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                        <!--  Grupo: Administración  -->
                        <NavigationViewItem
                            Background="{ThemeResource ControlElevationBorderBrush}"
                            Content="Administración"
                            IsExpanded="True">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE7EF;" />
                            </NavigationViewItem.Icon>
                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem
                                    Content="Administración"
                                    Icon="Setting"
                                    Tag="Administracion" />
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                        <!--  Grupo: DevOps  -->
                        <NavigationViewItem
                            Background="{ThemeResource ControlElevationBorderBrush}"
                            Content="DevOps"
                            Icon="ReportHacked"
                            IsExpanded="True">
                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem
                                    Content="Herramientas"
                                    Icon="Repair"
                                    Tag="DevOps" />
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                    </NavigationView.MenuItems>
                    <Frame x:Name="contentFrame" />
                </NavigationView>
            </Grid>

        </Grid>
        <Grid
            x:Name="Notificaciones"
            Grid.Row="0"
            Grid.Column="1"
            Padding="10"
            Visibility="{Binding IsNotificacionesVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <TextBlock
                Grid.Row="0"
                Margin="0,0,0,10"
                FontSize="14"
                FontWeight="SemiBold"
                Text="Notificaciones" />

            <!--  Alertas inteligentes del sistema  -->
            <StackPanel
                Grid.Row="1"
                Margin="0,0,0,8"
                Visibility="{Binding HasAlertasDb, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource SystemFillColorCautionBrush}"
                        Text="⚠ Alertas del sistema" />
                    <Button
                        x:Name="DescartarAlertasButton"
                        Grid.Column="1"
                        Padding="4,2"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="DescartarAlertas_Click"
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        ToolTipService.ToolTip="Marcar todas como vistas">
                        <FontIcon FontSize="11" Glyph="&#xE8BB;" />
                    </Button>
                </Grid>
                <ItemsRepeater ItemsSource="{Binding AlertasDb}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="4" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate xmlns:models="using:Advance_Control.Models" x:DataType="models:NotificacionAlerta">
                            <Border
                                Padding="10,8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                                BorderThickness="1,1,1,2"
                                CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        Grid.Column="0"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Top"
                                        FontSize="14"
                                        Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                        Glyph="{x:Bind Icono}" />
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock
                                            FontSize="12"
                                            Text="{x:Bind Titulo}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind Origen}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>

            <!--  Notification List (UI toasts)  -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Notificaciones}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,8"
                                Padding="10"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <!--  Título  -->
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="Bold"
                                            Text="{Binding Titulo}"
                                            TextWrapping="Wrap" />

                                        <!--  Nota  -->
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding Nota}"
                                            TextWrapping="Wrap"
                                            Visibility="{Binding Nota, Converter={StaticResource NullToVisibilityConverter}}" />

                                        <!--  Fecha de Inicio  -->
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Visibility="{Binding FechaHoraInicio, Converter={StaticResource NullToVisibilityConverter}}">
                                            <Run Text="Inicio: " />
                                            <Run Text="{Binding FechaHoraInicio, Converter={StaticResource DateTimeFormatConverter}}" />
                                        </TextBlock>

                                        <!--  Fecha Final  -->
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Visibility="{Binding FechaHoraFinal, Converter={StaticResource NullToVisibilityConverter}}">
                                            <Run Text="Final: " />
                                            <Run Text="{Binding FechaHoraFinal, Converter={StaticResource DateTimeFormatConverter}}" />
                                        </TextBlock>

                                        <!--  Fecha de Creación  -->
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                            Text="{Binding FechaCreacion, Converter={StaticResource DateTimeFormatConverter}}" />
                                    </StackPanel>

                                    <!--  Delete Button  -->
                                    <Button
                                        Grid.Column="1"
                                        Padding="8"
                                        VerticalAlignment="Top"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.EliminarNotificacionCommand, ElementName=RootGrid}"
                                        CommandParameter="{Binding Id}"
                                        ToolTipService.ToolTip="Eliminar notificación">
                                        <SymbolIcon Symbol="Delete" />
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!--  (Sección de silenciadas eliminada)  -->
        </Grid>
        <Grid
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Padding="12,0"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="6">
                <Ellipse
                    Width="8"
                    Height="8"
                    Fill="{ThemeResource SystemFillColorSuccessBrush}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="En línea" />
            </StackPanel>
        </Grid>
    </Grid>


</Window>
