<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Advance_Control.Views.Pages.MensajesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:items="using:Advance_Control.Views.Items.Mensajeria"
    xmlns:models="using:Advance_Control.Models"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Panel izquierdo: Lista de usuarios  -->
        <Grid Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <StackPanel Grid.Row="0" Padding="16,12" Spacing="4">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Mensajes" />
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Ellipse
                        Width="8" Height="8"
                        Fill="{x:Bind GetConnectionColor(ViewModel.EstaConectado), Mode=OneWay}" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.EstadoConexion, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>

            <!--  Buscador  -->
            <AutoSuggestBox
                x:Name="BuscadorUsuarios"
                Grid.Row="1"
                Margin="12,0,12,8"
                PlaceholderText="Buscar usuario…"
                QueryIcon="Find"
                TextChanged="BuscadorUsuarios_TextChanged" />

            <!--  Lista de usuarios  -->
            <ListView
                x:Name="UsuariosListView"
                Grid.Row="2"
                ItemsSource="{x:Bind ViewModel.Usuarios, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.UsuarioSeleccionado, Mode=TwoWay}"
                SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:UsuarioChatDto">
                        <items:UsuarioChatItemView />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!--  Panel derecho: Área de chat  -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Header del chat  -->
            <Border
                Grid.Row="0"
                Padding="16,12"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
                <Grid Visibility="{x:Bind ViewModel.HayUsuarioSeleccionado, Mode=OneWay}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Width="36" Height="36" Margin="0,0,12,0">
                        <Ellipse
                            Width="36" Height="36"
                            Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            FontSize="13" FontWeight="SemiBold"
                            Foreground="White"
                            Text="{x:Bind GetUsuarioIniciales(ViewModel.UsuarioSeleccionado), Mode=OneWay}" />
                    </Grid>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock
                            FontSize="15" FontWeight="SemiBold"
                            Text="{x:Bind GetUsuarioNombre(ViewModel.UsuarioSeleccionado), Mode=OneWay}" />
                        <TextBlock
                            FontSize="11"
                            Foreground="#10B981"
                            Text="En línea"
                            Visibility="{x:Bind GetUsuarioEnLineaVisibility(ViewModel.UsuarioSeleccionado), Mode=OneWay}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!--  Área de mensajes  -->
            <ListView
                x:Name="MensajesListView"
                Grid.Row="1"
                Padding="16,8"
                AllowDrop="True"
                DragOver="ChatArea_DragOver"
                Drop="ChatArea_Drop"
                ItemsSource="{x:Bind ViewModel.Mensajes, Mode=OneWay}"
                SelectionMode="None">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsStackPanel ItemsUpdatingScrollMode="KeepLastItemInView" VerticalAlignment="Bottom" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0,2" />
                        <Setter Property="MinHeight" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:MensajeDto">
                        <items:MensajeBurbujaItemView PdfButtonClick="BurbujaPdfButton_Click" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!--  Estado vacío  -->
            <StackPanel
                Grid.Row="1"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Spacing="8"
                Visibility="{x:Bind GetEmptyVisibility(ViewModel.HayUsuarioSeleccionado), Mode=OneWay}">
                <FontIcon FontSize="48" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="&#xE8BD;" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="16"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Selecciona un usuario para iniciar una conversación" />
            </StackPanel>

            <!--  Barra de entrada de texto  -->
            <Grid
                Grid.Row="2"
                Padding="16,8"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                ColumnSpacing="8"
                Visibility="{x:Bind ViewModel.HayUsuarioSeleccionado, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!--  Botón adjuntar imagen  -->
                <Button
                    Grid.Column="0"
                    Width="40" Height="40"
                    Click="AdjuntarButton_Click"
                    CornerRadius="20"
                    IsEnabled="{x:Bind ViewModel.EstaConectado, Mode=OneWay}"
                    ToolTipService.ToolTip="Adjuntar imagen">
                    <FontIcon FontSize="16" Glyph="&#xE7C5;" />
                </Button>
                <TextBox
                    x:Name="MensajeTextBox"
                    Grid.Column="1"
                    MaxHeight="100"
                    AcceptsReturn="False"
                    KeyDown="MensajeTextBox_KeyDown"
                    PlaceholderText="Escribe un mensaje o arrastra una imagen…"
                    Text="{x:Bind ViewModel.TextoMensaje, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextChanged="MensajeTextBox_TextChanged"
                    TextWrapping="Wrap" />
                <Button
                    Grid.Column="2"
                    Width="40" Height="40"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    Click="EnviarButton_Click"
                    CornerRadius="20"
                    IsEnabled="{x:Bind ViewModel.EstaConectado, Mode=OneWay}"
                    ToolTipService.ToolTip="Enviar">
                    <FontIcon FontSize="16" Foreground="White" Glyph="&#xE724;" />
                </Button>
            </Grid>

            <!--  Indicador de subida de imagen  -->
            <StackPanel
                Grid.Row="2"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Orientation="Horizontal" Spacing="8"
                Visibility="{x:Bind ViewModel.EnviandoImagen, Mode=OneWay}">
                <ProgressRing Width="20" Height="20" IsActive="{x:Bind ViewModel.EnviandoImagen, Mode=OneWay}" />
                <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Enviando imagen…" />
            </StackPanel>

            <!--  Cargando  -->
            <ProgressRing
                Grid.Row="1"
                Width="40" Height="40"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                IsActive="{x:Bind ViewModel.Cargando, Mode=OneWay}" />

            <!--  Error de diagnóstico  -->
            <TextBlock
                Grid.Row="1"
                Margin="16,8"
                VerticalAlignment="Top"
                FontSize="12"
                Foreground="Red"
                IsTextSelectionEnabled="True"
                Text="{x:Bind ViewModel.ErrorMensaje, Mode=OneWay}"
                TextWrapping="Wrap" />
        </Grid>
    </Grid>
</Page>
