<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Advance_Control.Views.Pages.MensajesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Advance_Control.Models"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Panel izquierdo: Lista de usuarios  -->
        <Grid Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <StackPanel Grid.Row="0" Padding="16,12" Spacing="4">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Mensajes" />
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Ellipse
                        Width="8" Height="8"
                        Fill="{x:Bind GetConnectionColor(ViewModel.EstaConectado), Mode=OneWay}" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.EstadoConexion, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>

            <!--  Buscador  -->
            <AutoSuggestBox
                x:Name="BuscadorUsuarios"
                Grid.Row="1"
                Margin="12,0,12,8"
                PlaceholderText="Buscar usuario…"
                QueryIcon="Find"
                TextChanged="BuscadorUsuarios_TextChanged" />

            <!--  Lista de usuarios  -->
            <ListView
                x:Name="UsuariosListView"
                Grid.Row="2"
                ItemsSource="{x:Bind ViewModel.Usuarios, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.UsuarioSeleccionado, Mode=TwoWay}"
                SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:UsuarioChatDto">
                        <Grid Padding="8,10" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  Avatar con indicador de estado  -->
                            <Grid Grid.Column="0" Width="40" Height="40">
                                <Ellipse
                                    Width="40" Height="40"
                                    Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                                <TextBlock
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    FontSize="14" FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="{x:Bind Iniciales}" />
                                <!--  Indicador en línea  -->
                                <Ellipse
                                    Width="12" Height="12"
                                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                    Fill="#10B981"
                                    Stroke="{ThemeResource LayerFillColorDefaultBrush}"
                                    StrokeThickness="2"
                                    Visibility="{x:Bind EstaEnLinea, Mode=OneWay}" />
                            </Grid>

                            <!--  Nombre y estado  -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock
                                    FontSize="13" FontWeight="SemiBold"
                                    Text="{x:Bind NombreVisible}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Escribiendo…"
                                    Visibility="{x:Bind EstaEscribiendo, Mode=OneWay}" />
                            </StackPanel>

                            <!--  Badge de no leídos  -->
                            <Border
                                Grid.Column="2"
                                MinWidth="20" Height="20"
                                Padding="5,0"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Background="{ThemeResource SystemFillColorCriticalBrush}"
                                CornerRadius="10"
                                Visibility="{x:Bind TieneNoLeidos, Mode=OneWay}">
                                <TextBlock
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    FontSize="11" FontWeight="Bold"
                                    Foreground="White"
                                    Text="{x:Bind MensajesNoLeidos, Mode=OneWay}" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!--  Panel derecho: Área de chat  -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Header del chat  -->
            <Border
                Grid.Row="0"
                Padding="16,12"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
                <Grid Visibility="{x:Bind ViewModel.HayUsuarioSeleccionado, Mode=OneWay}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Width="36" Height="36" Margin="0,0,12,0">
                        <Ellipse
                            Width="36" Height="36"
                            Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            FontSize="13" FontWeight="SemiBold"
                            Foreground="White"
                            Text="{x:Bind ViewModel.UsuarioSeleccionado.Iniciales, Mode=OneWay}" />
                    </Grid>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock
                            FontSize="15" FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.UsuarioSeleccionado.NombreVisible, Mode=OneWay}" />
                        <TextBlock
                            FontSize="11"
                            Foreground="#10B981"
                            Text="En línea"
                            Visibility="{x:Bind ViewModel.UsuarioSeleccionado.EstaEnLinea, Mode=OneWay}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!--  Área de mensajes  -->
            <ListView
                x:Name="MensajesListView"
                Grid.Row="1"
                Padding="16,8"
                AllowDrop="True"
                DragOver="ChatArea_DragOver"
                Drop="ChatArea_Drop"
                ItemsSource="{x:Bind ViewModel.Mensajes, Mode=OneWay}"
                SelectionMode="None">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsStackPanel ItemsUpdatingScrollMode="KeepLastItemInView" VerticalAlignment="Bottom" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0,2" />
                        <Setter Property="MinHeight" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:MensajeDto">
                        <Grid>
                            <!--  Mensaje propio (derecha)  -->
                            <Border
                                MaxWidth="400"
                                Margin="80,2,0,2"
                                Padding="12,8"
                                HorizontalAlignment="Right"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="12,12,4,12"
                                Visibility="{x:Bind EsMio}">
                                <StackPanel>
                                    <!--  Imagen  -->
                                    <Image
                                        MaxWidth="300" MaxHeight="300"
                                        Margin="0,0,0,4"
                                        Source="{x:Bind ImagenUrlCompleta}"
                                        Stretch="Uniform"
                                        Visibility="{x:Bind EsImagen}" />
                                    <!--  PDF  -->
                                    <Button
                                        Margin="0,0,0,4"
                                        Padding="10,8"
                                        Background="#22FFFFFF"
                                        Click="PdfButton_Click"
                                        CornerRadius="8"
                                        Tag="{x:Bind ImagenUrlCompleta}"
                                        Visibility="{x:Bind EsPdf}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="20" Foreground="White" Glyph="&#xEA90;" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="12" Foreground="White"
                                                Text="{x:Bind Contenido}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Button>
                                    <!--  Texto  -->
                                    <TextBlock
                                        FontSize="13" Foreground="White"
                                        Text="{x:Bind Contenido}"
                                        TextWrapping="Wrap"
                                        Visibility="{x:Bind EsTexto}" />
                                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="4">
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="#CCFFFFFF"
                                            Text="{x:Bind HoraFormateada}" />
                                        <FontIcon
                                            FontSize="10"
                                            Foreground="#CCFFFFFF"
                                            Glyph="{x:Bind GetReadIcon(EsLeido)}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!--  Mensaje del otro (izquierda)  -->
                            <Border
                                MaxWidth="400"
                                Margin="0,2,80,2"
                                Padding="12,8"
                                HorizontalAlignment="Left"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="12,12,12,4"
                                Visibility="{x:Bind NotEsMio}">
                                <StackPanel>
                                    <!--  Imagen  -->
                                    <Image
                                        MaxWidth="300" MaxHeight="300"
                                        Margin="0,0,0,4"
                                        Source="{x:Bind ImagenUrlCompleta}"
                                        Stretch="Uniform"
                                        Visibility="{x:Bind EsImagen}" />
                                    <!--  PDF  -->
                                    <Button
                                        Margin="0,0,0,4"
                                        Padding="10,8"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                        Click="PdfButton_Click"
                                        CornerRadius="8"
                                        Tag="{x:Bind ImagenUrlCompleta}"
                                        Visibility="{x:Bind EsPdf}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="20" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Glyph="&#xEA90;" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Text="{x:Bind Contenido}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Button>
                                    <!--  Texto  -->
                                    <TextBlock
                                        FontSize="13"
                                        Text="{x:Bind Contenido}"
                                        TextWrapping="Wrap"
                                        Visibility="{x:Bind EsTexto}" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontSize="10"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind HoraFormateada}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!--  Estado vacío  -->
            <StackPanel
                Grid.Row="1"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Spacing="8"
                Visibility="{x:Bind GetEmptyVisibility(ViewModel.HayUsuarioSeleccionado), Mode=OneWay}">
                <FontIcon FontSize="48" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="&#xE8BD;" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="16"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Selecciona un usuario para iniciar una conversación" />
            </StackPanel>

            <!--  Barra de entrada de texto  -->
            <Grid
                Grid.Row="2"
                Padding="16,8"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                ColumnSpacing="8"
                Visibility="{x:Bind ViewModel.HayUsuarioSeleccionado, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!--  Botón adjuntar imagen  -->
                <Button
                    Grid.Column="0"
                    Width="40" Height="40"
                    Click="AdjuntarButton_Click"
                    CornerRadius="20"
                    IsEnabled="{x:Bind ViewModel.EstaConectado, Mode=OneWay}"
                    ToolTipService.ToolTip="Adjuntar imagen">
                    <FontIcon FontSize="16" Glyph="&#xE7C5;" />
                </Button>
                <TextBox
                    x:Name="MensajeTextBox"
                    Grid.Column="1"
                    MaxHeight="100"
                    AcceptsReturn="False"
                    KeyDown="MensajeTextBox_KeyDown"
                    PlaceholderText="Escribe un mensaje o arrastra una imagen…"
                    Text="{x:Bind ViewModel.TextoMensaje, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextChanged="MensajeTextBox_TextChanged"
                    TextWrapping="Wrap" />
                <Button
                    Grid.Column="2"
                    Width="40" Height="40"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    Click="EnviarButton_Click"
                    CornerRadius="20"
                    IsEnabled="{x:Bind ViewModel.EstaConectado, Mode=OneWay}"
                    ToolTipService.ToolTip="Enviar">
                    <FontIcon FontSize="16" Foreground="White" Glyph="&#xE724;" />
                </Button>
            </Grid>

            <!--  Indicador de subida de imagen  -->
            <StackPanel
                Grid.Row="2"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Orientation="Horizontal" Spacing="8"
                Visibility="{x:Bind ViewModel.EnviandoImagen, Mode=OneWay}">
                <ProgressRing Width="20" Height="20" IsActive="{x:Bind ViewModel.EnviandoImagen, Mode=OneWay}" />
                <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Enviando imagen…" />
            </StackPanel>

            <!--  Cargando  -->
            <ProgressRing
                Grid.Row="1"
                Width="40" Height="40"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                IsActive="{x:Bind ViewModel.Cargando, Mode=OneWay}" />
        </Grid>
    </Grid>
</Page>
