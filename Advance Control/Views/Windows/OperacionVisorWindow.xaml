<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Advance_Control.Views.Windows.OperacionVisorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Advance_Control.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Advance_Control.Models"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <converters:CurrencyConverter x:Key="CurrencyConverter" />
            <converters:BooleanToSystemColorBrushConverter x:Key="BoolToColorBrushConverter" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Barra de título  -->
        <Grid
            Grid.Row="0"
            Padding="20,0"
            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <StackPanel
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="12">
                <SymbolIcon Symbol="Document" />
                <TextBlock
                    FontSize="15"
                    FontWeight="SemiBold"
                    Text="{x:Bind Operacion.Identificador, Mode=OneWay}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="13"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind Operacion.RazonSocial, Mode=OneWay}" />
                <Border
                    Padding="6,2"
                    VerticalAlignment="Center"
                    Background="#152DA44E"
                    BorderBrush="#2DA44E"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{x:Bind ToBoolVisibility(Operacion.IsEditable), Mode=OneWay}">
                    <TextBlock
                        FontSize="11"
                        Foreground="#2DA44E"
                        Text="● Abierta" />
                </Border>
                <Border
                    Padding="6,2"
                    VerticalAlignment="Center"
                    Background="#15808080"
                    BorderBrush="#808080"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{x:Bind ToBoolVisibility(Operacion.IsFinalized), Mode=OneWay}">
                    <TextBlock
                        FontSize="11"
                        Foreground="#808080"
                        Text="✓ Finalizada" />
                </Border>
            </StackPanel>
        </Grid>

        <!--  Contenido en 3 paneles  -->
        <Grid Grid.Row="1">
            <TabView
                x:Name="MainTabView"
                VerticalAlignment="Stretch"
                CanDragTabs="False"
                CanReorderTabs="False"
                IsAddTabButtonVisible="False"
                SelectionChanged="MainTabView_SelectionChanged">

                <TabViewItem IsClosable="False">
                    <TabViewItem.IconSource>
                        <SymbolIconSource Symbol="Document" />
                    </TabViewItem.IconSource>

                    <TabViewItem.Header>
                        <TextBlock Text="Cargos" />
                    </TabViewItem.Header>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="250" />
                        </Grid.ColumnDefinitions>
                        <Grid
                            Grid.Column="0"
                            Padding="10"
                            VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!--  Encabezado  -->
                                    <Grid
                                        Grid.Row="0"
                                        Margin="0,0,0,2"
                                        Padding="8,6"
                                        Background="{ThemeResource CardStrokeColorDefaultSolid}"
                                        CornerRadius="6,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="250" />
                                            <ColumnDefinition Width="65" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="44" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Tipo" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Detalle" />
                                        <TextBlock
                                            Grid.Column="2"
                                            HorizontalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Cant." />
                                        <TextBlock
                                            Grid.Column="3"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Unitario" />
                                        <TextBlock
                                            Grid.Column="4"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Monto" />
                                        <TextBlock
                                            Grid.Column="5"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Nota" />
                                        <TextBlock
                                            Grid.Column="6"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Proveedor" />
                                        <TextBlock
                                            Grid.Column="7"
                                            HorizontalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Sel."
                                            ToolTipService.ToolTip="Seleccionar" />
                                    </Grid>

                                    <!--  Indicador de carga + Sin cargos (comparten fila, son mutuamente exclusivos)  -->
                                    <StackPanel
                                        Grid.Row="1"
                                        Margin="0,24"
                                        HorizontalAlignment="Center"
                                        Spacing="8"
                                        Visibility="{x:Bind ToBoolVisibility(Operacion.IsLoadingCargos), Mode=OneWay}">
                                        <ProgressRing
                                            Width="28"
                                            Height="28"
                                            HorizontalAlignment="Center"
                                            IsActive="True" />
                                        <TextBlock
                                            FontSize="12"
                                            FontStyle="Italic"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="Cargando cargos..." />
                                    </StackPanel>

                                    <!--  Sin cargos registrados  -->
                                    <StackPanel
                                        Grid.Row="1"
                                        Margin="0,24"
                                        HorizontalAlignment="Center"
                                        Spacing="6"
                                        Visibility="{x:Bind ToBoolVisibility(Operacion.ShowNoCargosMessage), Mode=OneWay}">
                                        <FontIcon
                                            HorizontalAlignment="Center"
                                            FontSize="24"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Glyph="&#xE8F4;" />
                                        <TextBlock
                                            FontSize="12"
                                            FontStyle="Italic"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Text="Sin cargos registrados" />
                                    </StackPanel>

                                </Grid>
                            </Grid>

                            <Grid Grid.Row="1">
                                <ItemsRepeater Grid.Row="2" ItemsSource="{x:Bind Operacion.Cargos, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="5" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:CargoDto">
                                            <StackPanel
                                                Background="{ThemeResource ControlElevationBorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                CornerRadius="5"
                                                Tapped="CargoRow_Tapped">
                                                <Grid Height="50" Padding="8,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="250" />
                                                        <ColumnDefinition Width="65" />
                                                        <ColumnDefinition Width="110" />
                                                        <ColumnDefinition Width="110" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="110" />
                                                        <ColumnDefinition Width="44" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel
                                                        Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        Orientation="Horizontal"
                                                        Spacing="8">
                                                        <TextBlock
                                                            FontSize="12"
                                                            Text="{x:Bind TipoCargo, Mode=OneWay}"
                                                            TextTrimming="CharacterEllipsis" />
                                                        <FontIcon
                                                            FontSize="11"
                                                            Foreground="{ThemeResource SystemAccentColor}"
                                                            Glyph="&#xE722;"
                                                            ToolTipService.ToolTip="Tiene imágenes"
                                                            Visibility="{x:Bind HasImagesVisibility, Mode=OneWay}" />
                                                    </StackPanel>

                                                    <Grid Grid.Column="1">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*" />
                                                            <RowDefinition Height="*" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock
                                                            Grid.Row="0"
                                                            FontSize="12"
                                                            FontWeight="SemiBold"
                                                            Text="{x:Bind DetalleLinea1, Mode=OneWay}"
                                                            TextWrapping="Wrap"
                                                            ToolTipService.ToolTip="{x:Bind DetalleLinea1, Mode=OneWay}" />
                                                        <TextBlock
                                                            Grid.Row="1"
                                                            FontSize="11"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            Text="{x:Bind DetalleLinea2, Mode=OneWay}"
                                                            TextWrapping="Wrap"
                                                            ToolTipService.ToolTip="{x:Bind DetalleLinea2, Mode=OneWay}"
                                                            Visibility="{x:Bind SubdetalleVisibility, Mode=OneWay}" />
                                                        <TextBlock
                                                            Grid.Row="2"
                                                            FontSize="11"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            Text="{x:Bind DetalleLinea3, Mode=OneWay}"
                                                            TextWrapping="Wrap"
                                                            ToolTipService.ToolTip="{x:Bind DetalleLinea3, Mode=OneWay}"
                                                            Visibility="{x:Bind SubdetalleVisibility, Mode=OneWay}" />

                                                    </Grid>

                                                    <!--  Cantidad  -->
                                                    <TextBlock
                                                        Grid.Column="2"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        Text="{x:Bind Cantidad, Mode=OneWay}"
                                                        Visibility="{x:Bind ReadVisibility, Mode=OneWay}" />
                                                    <TextBox
                                                        Grid.Column="2"
                                                        MinHeight="28"
                                                        Margin="0,0,4,0"
                                                        Padding="4,2"
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        KeyDown="CargoField_KeyDown"
                                                        Tag="{x:Bind}"
                                                        Text="{x:Bind Cantidad, Mode=TwoWay}"
                                                        Visibility="{x:Bind EditVisibility, Mode=OneWay}" />

                                                    <!--  Unitario  -->
                                                    <TextBlock
                                                        Grid.Column="3"
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        Text="{x:Bind UnitarioFormateado, Mode=OneWay}"
                                                        Visibility="{x:Bind ReadVisibility, Mode=OneWay}" />
                                                    <TextBox
                                                        Grid.Column="3"
                                                        MinHeight="28"
                                                        Margin="0,0,4,0"
                                                        Padding="4,2"
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        KeyDown="CargoField_KeyDown"
                                                        Tag="{x:Bind}"
                                                        Text="{x:Bind Unitario, Mode=TwoWay}"
                                                        Visibility="{x:Bind EditVisibility, Mode=OneWay}" />

                                                    <!--  Monto  -->
                                                    <TextBlock
                                                        Grid.Column="4"
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        Text="{x:Bind MontoFormateado, Mode=OneWay}" />

                                                    <!--  Nota  -->
                                                    <TextBlock
                                                        Grid.Column="5"
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        Text="{x:Bind Nota, Mode=OneWay}"
                                                        TextTrimming="CharacterEllipsis"
                                                        Visibility="{x:Bind ReadVisibility, Mode=OneWay}" />
                                                    <TextBox
                                                        Grid.Column="5"
                                                        MinHeight="28"
                                                        Margin="0,0,4,0"
                                                        Padding="4,2"
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        KeyDown="CargoField_KeyDown"
                                                        Tag="{x:Bind}"
                                                        Text="{x:Bind Nota, Mode=TwoWay}"
                                                        Visibility="{x:Bind EditVisibility, Mode=OneWay}" />

                                                    <!--  Proveedor  -->
                                                    <TextBlock
                                                        Grid.Column="6"
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        Text="{x:Bind Proveedor, Mode=OneWay}"
                                                        TextTrimming="CharacterEllipsis" />

                                                    <CheckBox
                                                        Grid.Column="7"
                                                        MinWidth="0"
                                                        Padding="0"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Checked="CargoCheckBox_Checked"
                                                        Unchecked="CargoCheckBox_UnChecked"
                                                        IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                        Tag="{x:Bind}" />
                                                </Grid>

                                                <!--  Galería de imágenes del cargo  -->
                                                <Grid
                                                    Padding="8,4"
                                                    Background="{ThemeResource ControlElevationBorderBrush}"
                                                    Visibility="{x:Bind GalleryVisibility, Mode=OneWay}">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock
                                                        Grid.Row="0"
                                                        Margin="5,0,0,5"
                                                        FontSize="11"
                                                        FontWeight="SemiBold"
                                                        Text="Imágenes:" />
                                                    <ItemsRepeater
                                                        Grid.Row="1"
                                                        Margin="5,5,0,5"
                                                        ItemsSource="{x:Bind Images, Mode=OneWay}">
                                                        <ItemsRepeater.Layout>
                                                            <StackLayout Orientation="Horizontal" Spacing="8" />
                                                        </ItemsRepeater.Layout>
                                                        <ItemsRepeater.ItemTemplate>
                                                            <DataTemplate x:DataType="models:CargoImageDto">
                                                                <Grid
                                                                    Width="120"
                                                                    Height="120"
                                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                                                    <Button
                                                                        Padding="0"
                                                                        HorizontalAlignment="Stretch"
                                                                        VerticalAlignment="Stretch"
                                                                        Background="Transparent"
                                                                        BorderThickness="0"
                                                                        Click="ViewCargoImageButton_Click"
                                                                        CornerRadius="5,0,5,0"
                                                                        Tag="{x:Bind}"
                                                                        ToolTipService.ToolTip="Ver imagen">
                                                                        <Image
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"
                                                                            Source="{x:Bind converters:FilePathToImageConverter.ToImage(Url), Mode=OneWay}"
                                                                            Stretch="UniformToFill" />
                                                                    </Button>
                                                                    <Button
                                                                        MinWidth="18"
                                                                        MinHeight="18"
                                                                        Margin="0,2,2,0"
                                                                        Padding="3"
                                                                        HorizontalAlignment="Right"
                                                                        VerticalAlignment="Top"
                                                                        Background="#CC000000"
                                                                        Click="DeleteCargoImageButton_Click"
                                                                        CornerRadius="9"
                                                                        Tag="{x:Bind}"
                                                                        ToolTipService.ToolTip="Eliminar imagen">
                                                                        <SymbolIcon Foreground="White" Symbol="Cancel" />
                                                                    </Button>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsRepeater.ItemTemplate>
                                                    </ItemsRepeater>
                                                </Grid>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Selección:" />
                                        <Button Click="UploadSelectedCargoImageButton_Click" ToolTipService.ToolTip="Cargar imagen al cargo seleccionado">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <SymbolIcon Symbol="Camera" />
                                                <TextBlock Text="Imagen" />
                                            </StackPanel>
                                        </Button>
                                        <Button Click="EditSelectedCargoButton_Click" ToolTipService.ToolTip="Editar cargo seleccionado">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <SymbolIcon Symbol="Edit" />
                                                <TextBlock Text="Editar" />
                                            </StackPanel>
                                        </Button>
                                        <Button Click="DeleteSelectedCargosButton_Click" ToolTipService.ToolTip="Eliminar cargos seleccionados">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <SymbolIcon Symbol="Delete" />
                                                <TextBlock Text="Eliminar" />
                                            </StackPanel>
                                        </Button>
                                        <Button Click="ViewSelectedRefaccionButton_Click" ToolTipService.ToolTip="Ver refacción seleccionada">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <SymbolIcon Symbol="View" />
                                                <TextBlock Text="Refacción" />
                                            </StackPanel>
                                        </Button>




                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Column="1">
                                    <StackPanel Orientation="Horizontal" Spacing="10">


                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Text="Total:" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Foreground="{ThemeResource TextBoxBorderThemeBrush}"
                                            Text="{x:Bind FormatDoubleCurrency(Operacion.TotalMonto), Mode=OneWay}" />
                                        <Button
                                            HorizontalAlignment="Right"
                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            Click="AddCargoButton_Click"
                                            Foreground="{ThemeResource FocusVisualBlackStrokeThemeBrush}"
                                            IsEnabled="{x:Bind Operacion.IsEditable, Mode=OneWay}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <SymbolIcon Symbol="Add" />
                                                <TextBlock Text="Agregar Cargo" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>

                        </Grid>
                        <Grid
                            Grid.Column="1"
                            Margin="0,9,5,10"
                            Padding="10"
                            Background="{ThemeResource AccentAAFillColorDisabled}"
                            CornerRadius="5">
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">

                                <StackPanel Spacing="12">
                                    <StackPanel Spacing="10">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon
                                                FontSize="14"
                                                Foreground="{ThemeResource SystemAccentColor}"
                                                Glyph="&#xE946;" />
                                            <TextBlock
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Text="Información" />
                                        </StackPanel>
                                        <Border
                                            Padding="10"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <Grid RowSpacing="4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock
                                                    Grid.Row="0"
                                                    Grid.Column="0"
                                                    Margin="0,0,10,0"
                                                    FontSize="12"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="Cliente" />
                                                <TextBlock
                                                    Grid.Row="0"
                                                    Grid.Column="1"
                                                    FontSize="12"
                                                    Text="{x:Bind Operacion.RazonSocial, Mode=OneWay}"
                                                    TextTrimming="CharacterEllipsis"
                                                    ToolTipService.ToolTip="{x:Bind Operacion.RazonSocial, Mode=OneWay}" />
                                                <TextBlock
                                                    Grid.Row="1"
                                                    Grid.Column="0"
                                                    Margin="0,0,10,0"
                                                    FontSize="12"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="Equipo" />
                                                <TextBlock
                                                    Grid.Row="1"
                                                    Grid.Column="1"
                                                    FontSize="12"
                                                    Text="{x:Bind Operacion.Identificador, Mode=OneWay}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Grid.Row="2"
                                                    Grid.Column="0"
                                                    Margin="0,0,10,0"
                                                    FontSize="12"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="Atiende" />
                                                <TextBlock
                                                    Grid.Row="2"
                                                    Grid.Column="1"
                                                    FontSize="12"
                                                    Text="{x:Bind Operacion.Atiende, Mode=OneWay}" />
                                                <TextBlock
                                                    Grid.Row="3"
                                                    Grid.Column="0"
                                                    Margin="0,0,10,0"
                                                    FontSize="12"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="Inicio" />
                                                <TextBlock
                                                    Grid.Row="3"
                                                    Grid.Column="1"
                                                    FontSize="12"
                                                    Text="{x:Bind Operacion.FechaInicioCorta, Mode=OneWay}" />
                                                <TextBlock
                                                    Grid.Row="4"
                                                    Grid.Column="0"
                                                    Margin="0,0,10,0"
                                                    FontSize="12"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="Estado" />
                                                <TextBlock
                                                    Grid.Row="4"
                                                    Grid.Column="1"
                                                    FontSize="12"
                                                    Text="{x:Bind Operacion.StatusText, Mode=OneWay}" />
                                                <TextBlock
                                                    Grid.Row="5"
                                                    Grid.Column="0"
                                                    Margin="0,4,10,0"
                                                    FontSize="12"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="Nota"
                                                    Visibility="{x:Bind ToTextVisibility(Operacion.Nota), Mode=OneWay}" />
                                                <TextBlock
                                                    Grid.Row="5"
                                                    Grid.Column="1"
                                                    Margin="0,4,0,0"
                                                    FontSize="12"
                                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                    Text="{x:Bind Operacion.Nota, Mode=OneWay}"
                                                    TextWrapping="Wrap"
                                                    Visibility="{x:Bind ToTextVisibility(Operacion.Nota), Mode=OneWay}" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="20"
                                        Text="Tareas" />
                                    <!--  Barra de progreso  -->
                                    <Border
                                        Padding="12"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Visibility="{x:Bind ToBoolVisibility(Operacion.TieneCheck), Mode=OneWay}">
                                        <StackPanel Spacing="8">

                                            <ProgressBar Maximum="8" Value="{x:Bind Operacion.CkStepsCompletados, Mode=OneWay}" />
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                <Run FontWeight="Bold" Text="{x:Bind Operacion.CkStepsCompletados, Mode=OneWay}" />
                                                <Run Text="de 8 completados" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <!--  Lista de pasos  -->
                                    <ItemsRepeater ItemsSource="{x:Bind Operacion.CkPasos, Mode=OneWay}" Visibility="{x:Bind ToBoolVisibility(Operacion.TieneCheck), Mode=OneWay}">
                                        <ItemsRepeater.Layout>
                                            <StackLayout Spacing="4" />
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="models:CheckPasoItem">
                                                <Border
                                                    Padding="10,8"
                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6">
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <FontIcon
                                                            VerticalAlignment="Center"
                                                            FontSize="14"
                                                            Foreground="{x:Bind EstadoBrush, Mode=OneWay}"
                                                            Glyph="{x:Bind Glyph, Mode=OneWay}" />
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            Text="{x:Bind Nombre, Mode=OneWay}"
                                                            TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>

                                    <!--  Cargando tareas  -->
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8"
                                        Visibility="{x:Bind ToBoolVisibility(Operacion.IsLoadingCheck), Mode=OneWay}">
                                        <ProgressRing
                                            Width="28"
                                            Height="28"
                                            HorizontalAlignment="Center"
                                            IsActive="True" />
                                        <TextBlock
                                            FontSize="12"
                                            FontStyle="Italic"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="Cargando tareas..." />
                                    </StackPanel>

                                    <!--  Sin tareas registradas  -->
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8"
                                        Visibility="{x:Bind ToBoolVisibility(Operacion.ShowNoCheckMessage), Mode=OneWay}">
                                        <FontIcon
                                            FontSize="28"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Glyph="&#xE9D5;" />
                                        <TextBlock
                                            FontSize="12"
                                            FontStyle="Italic"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Text="Sin tareas registradas" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                </TabViewItem>
                <TabViewItem IsClosable="False">
                    <TabViewItem.IconSource>
                        <SymbolIconSource Symbol="Document" />
                    </TabViewItem.IconSource>

                    <TabViewItem.Header>
                        <TextBlock Text="Documentos" />
                    </TabViewItem.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid
                            Grid.Row="0"
                            Margin="10,10,10,10"
                            Background="{ThemeResource ControlElevationBorderBrush}">
                            <StackPanel
                                Margin="5"
                                Orientation="Horizontal"
                                Spacing="5">
                                <FontIcon
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="{ThemeResource SystemAccentColor}"
                                    Glyph="&#xE8A5;" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Text="Generar Documentos" />
                                <Button
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch"
                                    Click="GenerarCotizacionButton_Click"
                                    Style="{StaticResource AccentButtonStyle}"
                                    ToolTipService.ToolTip="Generar cotización PDF">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="Document" />
                                        <TextBlock Text="Cotización" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    Grid.Column="1"
                                    Margin="6,0,0,0"
                                    Padding="8"
                                    Click="AbrirCotizacionPdfButton_Click"
                                    ToolTipService.ToolTip="Abrir cotización PDF"
                                    Visibility="{x:Bind ToTextVisibility(Operacion.CotizacionPdfPath), Mode=OneWay}">
                                    <FontIcon FontSize="14" Glyph="&#xEA90;" />
                                </Button>
                                <Button
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch"
                                    Click="GenerarReporteButton_Click"
                                    Style="{StaticResource AccentButtonStyle}"
                                    ToolTipService.ToolTip="Generar reporte PDF">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="Pictures" />
                                        <TextBlock Text="Reporte" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    Grid.Column="1"
                                    Margin="6,0,0,0"
                                    Padding="8"
                                    Click="AbrirReportePdfButton_Click"
                                    ToolTipService.ToolTip="Abrir reporte PDF"
                                    Visibility="{x:Bind ToTextVisibility(Operacion.ReportePdfPath), Mode=OneWay}">
                                    <FontIcon FontSize="14" Glyph="&#xEA90;" />
                                </Button>
                            </StackPanel>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="10,8,10,12" Orientation="Vertical" Spacing="8">
                                <Border
                                    Padding="12"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <StackPanel Spacing="10">
                                         <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon
                                                FontSize="14"
                                                Foreground="{ThemeResource SystemAccentColor}"
                                                Glyph="&#xE898;" />
                                            <TextBlock
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Text="Cargar documentos" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <Button
                                                HorizontalAlignment="Stretch"
                                                Click="UploadPrefacturaButton_Click"
                                                IsEnabled="{x:Bind Operacion.IsEditable, Mode=OneWay}"
                                                ToolTipService.ToolTip="Cargar prefactura">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <FontIcon FontSize="12" Glyph="&#xE898;" />
                                                    <TextBlock FontSize="12" Text="Prefactura" />
                                                </StackPanel>
                                            </Button>
                                            <AppBarSeparator />
                                            <Button
                                                HorizontalAlignment="Stretch"
                                                Click="UploadHojaServicioButton_Click"
                                                IsEnabled="{x:Bind Operacion.IsEditable, Mode=OneWay}"
                                                ToolTipService.ToolTip="Cargar hoja de servicio">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <FontIcon FontSize="12" Glyph="&#xE898;" />
                                                    <TextBlock FontSize="12" Text="Hoja Serv." />
                                                </StackPanel>
                                            </Button>
                                            <AppBarSeparator />
                                            <Button
                                                HorizontalAlignment="Stretch"
                                                Click="UploadOrdenCompraButton_Click"
                                                IsEnabled="{x:Bind Operacion.IsEditable, Mode=OneWay}"
                                                ToolTipService.ToolTip="Cargar orden de compra">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <FontIcon FontSize="12" Glyph="&#xE898;" />
                                                    <TextBlock FontSize="12" Text="Orden C." />
                                                </StackPanel>
                                            </Button>
                                            <AppBarSeparator />
                                            <Button
                                                HorizontalAlignment="Stretch"
                                                Click="UploadLevantamientoButton_Click"
                                                IsEnabled="{x:Bind Operacion.IsEditable, Mode=OneWay}"
                                                ToolTipService.ToolTip="Cargar documento de levantamiento">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <FontIcon FontSize="12" Glyph="&#xE898;" />
                                                    <TextBlock FontSize="12" Text="Levantamiento" />
                                                </StackPanel>
                                            </Button>
                                            <AppBarSeparator />
                                            <Button
                                                HorizontalAlignment="Stretch"
                                                Click="UploadFacturaButton_Click"
                                                IsEnabled="{x:Bind Operacion.IsEditable, Mode=OneWay}"
                                                Style="{StaticResource AccentButtonStyle}"
                                                ToolTipService.ToolTip="Cargar factura PDF (finaliza la operación)">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <SymbolIcon Symbol="Attach" />
                                                    <TextBlock FontSize="12" Text="Factura" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <Button
                                            HorizontalAlignment="Stretch"
                                            Click="VerFacturaButton_Click"
                                            ToolTipService.ToolTip="Abrir factura PDF"
                                            Visibility="{x:Bind ToBoolVisibility(Operacion.HasFactura), Mode=OneWay}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <SymbolIcon Symbol="OpenFile" />
                                                <TextBlock Text="Ver Factura" />
                                            </StackPanel>
                                        </Button>
                                        <Button
                                            HorizontalAlignment="Stretch"
                                            Click="ReabrirOperacionButton_Click"
                                            Style="{StaticResource AccentButtonStyle}"
                                            ToolTipService.ToolTip="Reabrir operación finalizada"
                                            Visibility="{x:Bind ToInverseBoolVisibility(Operacion.IsEditable), Mode=OneWay}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon FontSize="14" Glyph="&#xE72C;" />
                                                <TextBlock Text="Reabrir Operación" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <!--  Hojas de servicio  -->
                                <Border
                                    x:Name="HojaServicioBorder"
                                    Padding="10"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{x:Bind ToBoolVisibility(Operacion.HasHojaServicio), Mode=OneWay}">
                                    <StackPanel Spacing="8">
                                        <TextBlock
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Hojas de servicio" />
                                        <ItemsRepeater ItemsSource="{x:Bind Operacion.ImagenesHojaServicio, Mode=OneWay}">
                                            <ItemsRepeater.Layout>
                                                <StackLayout Orientation="Horizontal" Spacing="6" />
                                            </ItemsRepeater.Layout>
                                             <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="models:OperacionImageDto">
                                                    <Grid
                                                        Width="88"
                                                        Height="88"
                                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                        CornerRadius="6">
                                                        <!--  Miniatura imagen  -->
                                                        <Button
                                                            Padding="0"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Click="ViewOperacionImageButton_Click"
                                                            CornerRadius="6"
                                                            Tag="{x:Bind}"
                                                            ToolTipService.ToolTip="Ver imagen"
                                                            Visibility="{x:Bind ImageVisibility, Mode=OneWay}">
                                                            <Image Source="{x:Bind converters:FilePathToImageConverter.ToImage(Url), Mode=OneWay}" Stretch="UniformToFill" />
                                                        </Button>
                                                        <!--  Miniatura PDF  -->
                                                        <Button
                                                            Padding="4"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Click="ViewOperacionImageButton_Click"
                                                            CornerRadius="6"
                                                            Tag="{x:Bind}"
                                                            ToolTipService.ToolTip="Abrir PDF"
                                                            Visibility="{x:Bind PdfVisibility, Mode=OneWay}">
                                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="3">
                                                                <FontIcon
                                                                    HorizontalAlignment="Center"
                                                                    FontSize="32"
                                                                    Foreground="#E05252"
                                                                    Glyph="&#xEA90;" />
                                                                <TextBlock
                                                                    HorizontalAlignment="Center"
                                                                    FontSize="9"
                                                                    MaxLines="2"
                                                                    Text="{x:Bind FileName, Mode=OneWay}"
                                                                    TextTrimming="CharacterEllipsis"
                                                                    TextWrapping="WrapWholeWords" />
                                                            </StackPanel>
                                                        </Button>
                                                        <!--  Eliminar  -->
                                                        <Button
                                                            MinWidth="18"
                                                            MinHeight="18"
                                                            Margin="0,2,2,0"
                                                            Padding="3"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Background="#CC000000"
                                                            Click="DeleteOperacionImageButton_Click"
                                                            CornerRadius="9"
                                                            Tag="{x:Bind}"
                                                            ToolTipService.ToolTip="Eliminar archivo">
                                                            <SymbolIcon Foreground="White" Symbol="Cancel" />
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </StackPanel>
                                </Border>

                                <!--  Prefacturas  -->
                                <Border
                                    x:Name="PrefacturaBorder"
                                    Padding="10"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{x:Bind ToBoolVisibility(Operacion.HasPrefactura), Mode=OneWay}">
                                    <StackPanel Spacing="8">
                                        <TextBlock
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Prefacturas" />
                                        <ItemsRepeater ItemsSource="{x:Bind Operacion.ImagenesPrefactura, Mode=OneWay}">
                                            <ItemsRepeater.Layout>
                                                <StackLayout Orientation="Horizontal" Spacing="6" />
                                            </ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="models:OperacionImageDto">
                                                    <Grid
                                                        Width="88"
                                                        Height="88"
                                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                        CornerRadius="6">
                                                        <Button
                                                            Padding="0"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Click="ViewOperacionImageButton_Click"
                                                            CornerRadius="6"
                                                            Tag="{x:Bind}"
                                                            ToolTipService.ToolTip="Ver imagen"
                                                            Visibility="{x:Bind ImageVisibility, Mode=OneWay}">
                                                            <Image Source="{x:Bind converters:FilePathToImageConverter.ToImage(Url), Mode=OneWay}" Stretch="UniformToFill" />
                                                        </Button>
                                                        <Button
                                                            Padding="4"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Click="ViewOperacionImageButton_Click"
                                                            CornerRadius="6"
                                                            Tag="{x:Bind}"
                                                            ToolTipService.ToolTip="Abrir PDF"
                                                            Visibility="{x:Bind PdfVisibility, Mode=OneWay}">
                                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="3">
                                                                <FontIcon
                                                                    HorizontalAlignment="Center"
                                                                    FontSize="32"
                                                                    Foreground="#E05252"
                                                                    Glyph="&#xEA90;" />
                                                                <TextBlock
                                                                    HorizontalAlignment="Center"
                                                                    FontSize="9"
                                                                    MaxLines="2"
                                                                    Text="{x:Bind FileName, Mode=OneWay}"
                                                                    TextTrimming="CharacterEllipsis"
                                                                    TextWrapping="WrapWholeWords" />
                                                            </StackPanel>
                                                        </Button>
                                                        <Button
                                                            MinWidth="18"
                                                            MinHeight="18"
                                                            Margin="0,2,2,0"
                                                            Padding="3"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Background="#CC000000"
                                                            Click="DeleteOperacionImageButton_Click"
                                                            CornerRadius="9"
                                                            Tag="{x:Bind}"
                                                            ToolTipService.ToolTip="Eliminar archivo">
                                                            <SymbolIcon Foreground="White" Symbol="Cancel" />
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </StackPanel>
                                </Border>

                                <!--  Órdenes de compra  -->
                                <Border
                                    x:Name="OrdenCompraBorder"
                                    Padding="10"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{x:Bind ToBoolVisibility(Operacion.HasOrdenCompra), Mode=OneWay}">
                                    <StackPanel Spacing="8">
                                        <TextBlock
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Órdenes de compra" />
                                        <ItemsRepeater ItemsSource="{x:Bind Operacion.ImagenesOrdenCompra, Mode=OneWay}">
                                            <ItemsRepeater.Layout>
                                                <StackLayout Orientation="Horizontal" Spacing="6" />
                                            </ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="models:OperacionImageDto">
                                                    <Grid
                                                        Width="88"
                                                        Height="88"
                                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                        CornerRadius="6">
                                                        <Button
                                                            Padding="0"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Click="ViewOperacionImageButton_Click"
                                                            CornerRadius="6"
                                                            Tag="{x:Bind}"
                                                            ToolTipService.ToolTip="Ver imagen"
                                                            Visibility="{x:Bind ImageVisibility, Mode=OneWay}">
                                                            <Image Source="{x:Bind converters:FilePathToImageConverter.ToImage(Url), Mode=OneWay}" Stretch="UniformToFill" />
                                                        </Button>
                                                        <Button
                                                            Padding="4"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Click="ViewOperacionImageButton_Click"
                                                            CornerRadius="6"
                                                            Tag="{x:Bind}"
                                                            ToolTipService.ToolTip="Abrir PDF"
                                                            Visibility="{x:Bind PdfVisibility, Mode=OneWay}">
                                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="3">
                                                                <FontIcon
                                                                    HorizontalAlignment="Center"
                                                                    FontSize="32"
                                                                    Foreground="#E05252"
                                                                    Glyph="&#xEA90;" />
                                                                <TextBlock
                                                                    HorizontalAlignment="Center"
                                                                    FontSize="9"
                                                                    MaxLines="2"
                                                                    Text="{x:Bind FileName, Mode=OneWay}"
                                                                    TextTrimming="CharacterEllipsis"
                                                                    TextWrapping="WrapWholeWords" />
                                                            </StackPanel>
                                                        </Button>
                                                        <Button
                                                            MinWidth="18"
                                                            MinHeight="18"
                                                            Margin="0,2,2,0"
                                                            Padding="3"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Background="#CC000000"
                                                            Click="DeleteOperacionImageButton_Click"
                                                            CornerRadius="9"
                                                            Tag="{x:Bind}"
                                                            ToolTipService.ToolTip="Eliminar archivo">
                                                            <SymbolIcon Foreground="White" Symbol="Cancel" />
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </StackPanel>
                                </Border>

                                <!--  Levantamientos  -->
                                <Border
                                    x:Name="LevantamientoBorder"
                                    Padding="10"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{x:Bind ToBoolVisibility(Operacion.HasLevantamiento), Mode=OneWay}">
                                    <StackPanel Spacing="8">
                                        <TextBlock
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Levantamientos" />
                                        <ItemsRepeater ItemsSource="{x:Bind Operacion.ImagenesLevantamiento, Mode=OneWay}">
                                            <ItemsRepeater.Layout>
                                                <StackLayout Orientation="Horizontal" Spacing="6" />
                                            </ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="models:OperacionImageDto">
                                                    <Grid
                                                        Width="88"
                                                        Height="88"
                                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                        CornerRadius="6">
                                                        <Button
                                                            Padding="0"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Click="ViewOperacionImageButton_Click"
                                                            CornerRadius="6"
                                                            Tag="{x:Bind}"
                                                            ToolTipService.ToolTip="Ver imagen"
                                                            Visibility="{x:Bind ImageVisibility, Mode=OneWay}">
                                                            <Image Source="{x:Bind converters:FilePathToImageConverter.ToImage(Url), Mode=OneWay}" Stretch="UniformToFill" />
                                                        </Button>
                                                        <Button
                                                            Padding="4"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Click="ViewOperacionImageButton_Click"
                                                            CornerRadius="6"
                                                            Tag="{x:Bind}"
                                                            ToolTipService.ToolTip="Abrir PDF"
                                                            Visibility="{x:Bind PdfVisibility, Mode=OneWay}">
                                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="3">
                                                                <FontIcon
                                                                    HorizontalAlignment="Center"
                                                                    FontSize="32"
                                                                    Foreground="#E05252"
                                                                    Glyph="&#xEA90;" />
                                                                <TextBlock
                                                                    HorizontalAlignment="Center"
                                                                    FontSize="9"
                                                                    MaxLines="2"
                                                                    Text="{x:Bind FileName, Mode=OneWay}"
                                                                    TextTrimming="CharacterEllipsis"
                                                                    TextWrapping="WrapWholeWords" />
                                                            </StackPanel>
                                                        </Button>
                                                        <Button
                                                            MinWidth="18"
                                                            MinHeight="18"
                                                            Margin="0,2,2,0"
                                                            Padding="3"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Background="#CC000000"
                                                            Click="DeleteOperacionImageButton_Click"
                                                            CornerRadius="9"
                                                            Tag="{x:Bind}"
                                                            ToolTipService.ToolTip="Eliminar archivo">
                                                            <SymbolIcon Foreground="White" Symbol="Cancel" />
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                    </Grid>

                </TabViewItem>

            </TabView>
        </Grid>
    </Grid>
</Window>
