<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Advance_Control.Views.Pages.FacturasView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Advance_Control.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource TitleTextBlockStyle}"
                Text="Facturas CFDI" />
            <Button
                x:Name="BtnCargarFacturaXml"
                Click="BtnCargarFacturaXml_Click"
                Content="Cargar XML"
                IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" />
            <Button
                x:Name="BtnCargarMultiplesFacturas"
                Click="BtnCargarMultiplesFacturas_Click"
                Content="Subir varios XML"
                IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" />
            <Button
                x:Name="BtnGuardarFactura"
                Click="BtnGuardarFactura_Click"
                Content="Guardar en servidor"
                IsEnabled="{x:Bind ViewModel.CanSave, Mode=OneWay}" />
            <Button
                x:Name="BtnActualizarFacturas"
                Click="BtnActualizarFacturas_Click"
                Content="Actualizar listado"
                IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ProgressRing
                Grid.Column="0"
                Width="40"
                Height="40"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

            <StackPanel Grid.Column="1">
                <InfoBar
                    IsClosable="True"
                    IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}"
                    Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    Severity="Error" />

                <InfoBar
                    Margin="0,8,0,0"
                    IsClosable="True"
                    IsOpen="{x:Bind ViewModel.SuccessMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}"
                    Message="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"
                    Severity="Success" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="2"
                CornerRadius="8">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Facturas guardadas" />
                        <TextBlock
                            Margin="0,4,0,0"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Selecciona una factura para abrir su detalle." />
                        <TextBlock
                            Margin="0,6,0,0"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind ViewModel.ResumenFacturasExistentes, Mode=OneWay}" />
                    </StackPanel>

                    <Border
                        Grid.Row="1"
                        Padding="12"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock FontWeight="SemiBold" Text="Filtros por fecha" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <CalendarDatePicker
                                    Grid.Column="0"
                                    Header="Desde"
                                    Date="{x:Bind ViewModel.FechaFiltroDesde, Mode=TwoWay}" />

                                <CalendarDatePicker
                                    Grid.Column="1"
                                    Header="Hasta"
                                    Date="{x:Bind ViewModel.FechaFiltroHasta, Mode=TwoWay}" />

                                <Button
                                    Grid.Column="2"
                                    VerticalAlignment="Bottom"
                                    Click="BtnLimpiarFiltrosFacturas_Click"
                                    Content="Limpiar" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <ListView
                        Grid.Row="2"
                        x:Name="FacturasListView"
                        Padding="8"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        IsItemClickEnabled="True"
                        ItemClick="FacturasListView_ItemClick"
                        ItemsSource="{x:Bind ViewModel.FacturasExistentes, Mode=OneWay}"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:FacturaResumenDto">
                                <Border
                                    Margin="0,0,0,10"
                                    Padding="12"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <StackPanel Spacing="6">
                                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding FolioTitulo}" />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding EmisorReceptorTexto}"
                                            TextWrapping="WrapWholeWords" />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding FechaTexto}" />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding TotalesTexto}"
                                            TextWrapping="WrapWholeWords" />
                                        <TextBlock FontWeight="SemiBold" Text="{Binding UuidTexto}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="20">
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="2"
                        CornerRadius="8"
                        Visibility="{x:Bind ViewModel.FacturaActual, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel Spacing="16">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Vista previa del XML cargado" />

                            <Grid ColumnSpacing="20" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="Folio:" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.FacturaActual.FolioTitulo, Mode=OneWay}" />
                                <TextBlock Grid.Row="0" Grid.Column="2" FontWeight="SemiBold" Text="Fecha:" />
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="{x:Bind ViewModel.FacturaActual.FechaTexto, Mode=OneWay}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Text="Emisor:" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.FacturaActual.EmisorNombre, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                <TextBlock Grid.Row="1" Grid.Column="2" FontWeight="SemiBold" Text="Receptor:" />
                                <TextBlock Grid.Row="1" Grid.Column="3" Text="{x:Bind ViewModel.FacturaActual.ReceptorNombre, Mode=OneWay}" TextWrapping="WrapWholeWords" />

                                <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="SemiBold" Text="Metodo / forma:" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.FacturaActual.MetodoFormaPagoTexto, Mode=OneWay}" />
                                <TextBlock Grid.Row="2" Grid.Column="2" FontWeight="SemiBold" Text="Lugar expedicion:" />
                                <TextBlock Grid.Row="2" Grid.Column="3" Text="{x:Bind ViewModel.FacturaActual.LugarExpedicionTexto, Mode=OneWay}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" FontWeight="SemiBold" Text="Totales:" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Text="{x:Bind ViewModel.FacturaActual.TotalesTexto, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="2"
                        CornerRadius="8"
                        Visibility="{x:Bind ViewModel.FacturaActual, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Conceptos de la factura" />
                            <ListView
                                ItemsSource="{x:Bind ViewModel.ConceptosFactura, Mode=OneWay}"
                                IsItemClickEnabled="False"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:FacturaConceptoDto">
                                        <Border
                                            Margin="0,0,0,8"
                                            Padding="10"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                            <StackPanel Spacing="6">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Descripcion}" TextWrapping="WrapWholeWords" />
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding ClavesTexto}" />
                                                <Grid ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="{Binding CantidadTexto}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding ValorUnitarioTexto}" />
                                                    <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding ImporteTexto}" />
                                                </Grid>
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{Binding ImpuestosTexto}"
                                                    TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="2"
                        CornerRadius="8"
                        Visibility="{x:Bind ViewModel.FacturaActual, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Traslados globales" />
                            <ListView
                                ItemsSource="{x:Bind ViewModel.TrasladosGlobales, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:FacturaTrasladoDto">
                                        <Grid Margin="0,0,0,8" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding ImpuestoResumen}" />
                                            <TextBlock Grid.Column="1" Text="{Binding BaseTexto}" />
                                            <TextBlock Grid.Column="2" Text="{Binding ImporteTexto}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
