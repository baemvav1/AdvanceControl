<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Advance_Control.Views.Items.Mensajeria.UsuarioChatItemView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="8,10" ColumnSpacing="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!--  Avatar con indicador de estado  -->
        <Grid Grid.Column="0" Width="40" Height="40">
            <Ellipse
                Width="40" Height="40"
                Fill="{ThemeResource AccentFillColorDefaultBrush}" />
            <TextBlock
                HorizontalAlignment="Center" VerticalAlignment="Center"
                FontSize="14" FontWeight="SemiBold"
                Foreground="White"
                Text="{Binding Iniciales}" />
            <!--  Indicador en línea  -->
            <Ellipse
                Width="12" Height="12"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Fill="#10B981"
                Stroke="{ThemeResource LayerFillColorDefaultBrush}"
                StrokeThickness="2"
                Visibility="{Binding EstaEnLinea, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>

        <!--  Nombre y estado  -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
            <TextBlock
                FontSize="13" FontWeight="SemiBold"
                Text="{Binding NombreVisible}"
                TextTrimming="CharacterEllipsis" />
            <TextBlock
                FontSize="11"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Escribiendo…"
                Visibility="{Binding EstaEscribiendo, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>

        <!--  Badge de no leídos  -->
        <Border
            Grid.Column="2"
            MinWidth="20" Height="20"
            Padding="5,0"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            Background="{ThemeResource SystemFillColorCriticalBrush}"
            CornerRadius="10"
            Visibility="{Binding TieneNoLeidos, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock
                HorizontalAlignment="Center" VerticalAlignment="Center"
                FontSize="11" FontWeight="Bold"
                Foreground="White"
                Text="{Binding MensajesNoLeidos, Mode=OneWay}" />
        </Border>
    </Grid>
</UserControl>
