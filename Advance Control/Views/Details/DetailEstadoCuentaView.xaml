<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Advance_Control.Views.Details.DetailEstadoCuentaView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:items="using:Advance_Control.Views.Items"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Advance_Control.Models"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource TitleTextBlockStyle}"
                Text="Detalle de estado de cuenta" />
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ProgressRing
                Grid.Column="0"
                Width="36"
                Height="36"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

            <InfoBar
                Grid.Column="1"
                IsClosable="True"
                IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                Severity="Error" />
        </Grid>

        <Grid Grid.Row="2">
            <Border
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="2"
                CornerRadius="8"
                Visibility="{x:Bind ViewModel.EstadoCuenta, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid ColumnSpacing="16" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="0"
                        Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="Período" />
                        <TextBlock Text="{x:Bind ViewModel.EstadoCuenta.PeriodoTexto, Mode=OneWay}" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.EstadoCuenta.FechaCorteTexto, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="1"
                        Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="Cuenta" />
                        <TextBlock Text="{x:Bind ViewModel.EstadoCuenta.CuentaTitulo, Mode=OneWay}" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind ViewModel.EstadoCuenta.BancoTitularTexto, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="2"
                        Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="Saldo inicial / final" />
                        <TextBlock Text="{x:Bind ViewModel.EstadoCuenta.SaldoInicialTexto, Mode=OneWay}" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.EstadoCuenta.SaldoFinalTexto, Mode=OneWay}" />
                    </StackPanel>

                    <Button
                        Grid.Row="0"
                        Grid.Column="3"
                        VerticalAlignment="Top"
                        Click="BtnAlternarFiltros_Click"
                        Content="{x:Bind ViewModel.TextoBotonFiltros, Mode=OneWay}" />

                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="0"
                        Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="CLABE" />
                        <TextBlock Text="{x:Bind ViewModel.EstadoCuenta.Clabe, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="1"
                        Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="Cargos / abonos" />
                        <TextBlock Text="{x:Bind ViewModel.EstadoCuenta.TotalCargosTexto, Mode=OneWay}" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.EstadoCuenta.TotalAbonosTexto, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="2"
                        Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="Resumen fiscal" />
                        <TextBlock Text="{x:Bind ViewModel.EstadoCuenta.FolioFiscalTexto, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.EstadoCuenta.TotalImpuestosTexto, Mode=OneWay}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3">
            <ScrollViewer>
                <StackPanel Spacing="16" Visibility="{x:Bind ViewModel.EstadoCuenta, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="2"
                        CornerRadius="8"
                        Visibility="{x:Bind ViewModel.IsFiltrosExpandidos, Mode=OneWay}">
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    Grid.Column="0"
                                    Header="Buscar dentro de los tipos seleccionados"
                                    PlaceholderText="Descripción, referencia, RFC, banco, concepto, folio..."
                                    Text="{x:Bind ViewModel.FiltroTexto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <NumberBox
                                    Grid.Column="1"
                                    Header="Buscar por monto"
                                    Minimum="0"
                                    PlaceholderText="Ej. 1250.00"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Compact"
                                    Value="{x:Bind ViewModel.FiltroMonto, Mode=TwoWay}" />

                                <ComboBox
                                    Grid.Column="2"
                                    Header="Conciliación"
                                    ItemsSource="{x:Bind ViewModel.OpcionesConciliacion, Mode=OneWay}"
                                    SelectedIndex="{x:Bind ViewModel.FiltroConciliacionIndex, Mode=TwoWay}" />

                                <TextBox
                                    Grid.Column="3"
                                    Header="Metadato"
                                    PlaceholderText="Buscar texto..."
                                    Text="{x:Bind ViewModel.FiltroMetadato, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <StackPanel
                                    Grid.Column="4"
                                    VerticalAlignment="Bottom"
                                    Spacing="6">
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.ResumenFiltros, Mode=OneWay}" />
                                    <Button
                                        HorizontalAlignment="Left"
                                        Click="BtnLimpiarFiltros_Click"
                                        Content="Restablecer filtros" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="6">
                                <TextBlock FontWeight="SemiBold" Text="Tipos de movimiento" />
                                <ItemsControl ItemsSource="{x:Bind ViewModel.FiltrosTipoMovimiento, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:FiltroTipoMovimientoDto">
                                            <CheckBox
                                                Margin="0,0,12,6"
                                                Content="{x:Bind EtiquetaCompleta}"
                                                IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="2"
                        CornerRadius="8">
                        <Grid RowSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Spacing="2">
                                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind ViewModel.ResumenGrupos, Mode=OneWay}" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.ResumenRelacionados, Mode=OneWay}" />
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <muxc:ItemsRepeater ItemsSource="{x:Bind ViewModel.GruposFiltrados, Mode=OneWay}">
                                    <muxc:ItemsRepeater.Layout>
                                        <muxc:StackLayout Spacing="0" />
                                    </muxc:ItemsRepeater.Layout>
                                    <muxc:ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:EstadoCuentaGrupoDetalleDto">
                                            <items:MovimientoItemView />
                                        </DataTemplate>
                                    </muxc:ItemsRepeater.ItemTemplate>
                                </muxc:ItemsRepeater>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
