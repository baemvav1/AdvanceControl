<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Advance_Control.Views.Items.Conciliacion.ConciliacionMovimientoItemView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    mc:Ignorable="d">
    <!--<TextBlock
    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
    Text="{Binding Movimiento.PendienteTexto, ElementName=Root}" />-->
    <Border
        Margin="10,0,15,0"
        Padding="12"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8">
        <StackPanel Spacing="10">
            <Grid ColumnSpacing="10">

                <StackPanel Spacing="2">

                    <TextBlock
                        Text="{Binding Movimiento.Descripcion, ElementName=Root}"
                        TextAlignment="Justify"
                        TextWrapping="Wrap" />

                    <Border
                        Margin="10"
                        Padding="12"
                        HorizontalAlignment="Stretch"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="Fecha" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding Movimiento.FechaTexto, ElementName=Root}" />


                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="Referencia" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding Movimiento.ReferenciaTexto, ElementName=Root}" />

                            </StackPanel>
                            <StackPanel
                                Grid.Column="2"
                                HorizontalAlignment="Center"
                                Spacing="4">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="Abono" />
                                <TextBlock HorizontalAlignment="Center" Text="{Binding Movimiento.AbonoTexto, ElementName=Root}" />
                            </StackPanel>
                        </Grid>
                    </Border>


                </StackPanel>
            </Grid>




            <StackPanel Spacing="2" />
        </StackPanel>
    </Border>
</UserControl>
