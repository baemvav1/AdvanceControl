<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Advance_Control.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Advance_Control" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" Title="Advance Control" mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="8*" />
            <ColumnDefinition x:Name="NotificacionesColumn" Width="2*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid x:Name="TopBar" Grid.Row="0">
                <Grid Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <!--  Botón login/logout con PersonPicture  -->
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button
                                x:Name="LogIn" Width="36" Height="36" VerticalAlignment="Center"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                Click="LoginButton_Click" CornerRadius="18" Padding="0"
                                ToolTipService.ToolTip="Cuenta de usuario">
                                <TextBlock
                                    HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="Bold"
                                    Foreground="White"
                                    Text="{Binding UserInitials}" />
                            </Button>
                            <TextBlock
                                VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                Text="{Binding UserType}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Column="1">
                        <TextBlock
                            VerticalAlignment="Center" FontSize="15" FontWeight="Bold"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            Text="Advance Control" HorizontalAlignment="Center" />
                    </Grid>

                    <Grid Grid.Column="2">
                        <Button 
                            x:Name="ToggleNotificacionesButton"
                            Click="ToggleNotificaciones_Click" 
                            HorizontalAlignment="Right"
                            Width="36"
                            Height="36"
                            Padding="0"
                            CornerRadius="18"
                            ToolTipService.ToolTip="Notificaciones"
                            Background="{Binding HasUnseenNotifications, Converter={StaticResource NotificationColorConverter}}">
                            <FontIcon 
                                Glyph="&#xEA8F;"
                                FontSize="16"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
            <Grid Grid.Row="1">
                <NavigationView
                    x:Name="nvSample" IsBackButtonVisible="Auto"
                    IsBackEnabled="{Binding IsBackEnabled, Mode=OneWay}">
                    <NavigationView.MenuItems>
                        <NavigationViewItem Content="Inicio" Tag="Inicio">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE80F;" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItemSeparator />

                        <!-- Grupo: Negocios -->
                        <NavigationViewItem Content="Negocios" IsExpanded="True">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE9F9;" />
                            </NavigationViewItem.Icon>
                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem
                                    Content="Operaciones" Icon="Calculator" Tag="Operaciones" />
                                <NavigationViewItem
                                    Content="Asesoría" Icon="ContactInfo" Tag="Asesoria" />
                                <NavigationViewItem
                                    Content="Mantenimiento" Icon="Repair" Tag="Mantenimiento" />
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                        <!-- Grupo: Clientes -->
                        <NavigationViewItem Content="Clientes" IsExpanded="True">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE716;" />
                            </NavigationViewItem.Icon>
                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem
                                    Content="Clientes" Icon="People" Tag="Clientes" />
                                <NavigationViewItem
                                    Content="Contactos" Icon="Contact2" Tag="Contactos" />
                                <NavigationViewItem
                                    Content="Entidades" Icon="Library" Tag="Entidades" />
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                        <!-- Grupo: Catálogos -->
                        <NavigationViewItem Content="Catálogos" IsExpanded="True">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE7C8;" />
                            </NavigationViewItem.Icon>
                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem
                                    Content="Equipos" Icon="AllApps" Tag="Equipos" />
                                <NavigationViewItem
                                    Content="Refacciones" Icon="Setting" Tag="Refacciones" />
                                <NavigationViewItem
                                    Content="Servicios" Icon="Repair" Tag="Servicios" />
                                <NavigationViewItem
                                    Content="Proveedores" Icon="Contact" Tag="Proveedores" />
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                        <!-- Grupo: Ubicaciones -->
                        <NavigationViewItem Content="Ubicaciones" IsExpanded="True">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE81D;" />
                            </NavigationViewItem.Icon>
                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem
                                    Content="Ubicaciones" Icon="MapPin" Tag="Ubicaciones" />
                                <NavigationViewItem
                                    Content="Áreas" Icon="Map" Tag="Areas" />
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                        <!-- Grupo: Financiero -->
                        <NavigationViewItem Content="Financiero" IsExpanded="True">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE7BF;" />
                            </NavigationViewItem.Icon>
                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem
                                    Content="Estado de Cuenta" Icon="Account" Tag="EsCuenta" />
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                    </NavigationView.MenuItems>
                    <Frame x:Name="contentFrame" />
                </NavigationView>
            </Grid>

        </Grid>
        <Grid
            x:Name="Notificaciones" Grid.Row="0" Grid.Column="1" Padding="10"
            Visibility="{Binding IsNotificacionesVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <TextBlock
                Grid.Row="0" Margin="0,0,0,10" FontSize="14"
                FontWeight="SemiBold" Text="Notificaciones" />

            <!--  Notification List  -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Notificaciones}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,8" Padding="10"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="4">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <!--  Título  -->
                                        <TextBlock
                                            FontSize="14" FontWeight="Bold"
                                            Text="{Binding Titulo}"
                                            TextWrapping="Wrap" />

                                        <!--  Nota  -->
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding Nota}"
                                            TextWrapping="Wrap"
                                            Visibility="{Binding Nota, Converter={StaticResource NullToVisibilityConverter}}" />

                                        <!--  Fecha de Inicio  -->
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Visibility="{Binding FechaHoraInicio, Converter={StaticResource NullToVisibilityConverter}}">
                                            <Run Text="Inicio: " />
                                            <Run Text="{Binding FechaHoraInicio, Converter={StaticResource DateTimeFormatConverter}}" />
                                        </TextBlock>

                                        <!--  Fecha Final  -->
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Visibility="{Binding FechaHoraFinal, Converter={StaticResource NullToVisibilityConverter}}">
                                            <Run Text="Final: " />
                                            <Run Text="{Binding FechaHoraFinal, Converter={StaticResource DateTimeFormatConverter}}" />
                                        </TextBlock>

                                        <!--  Fecha de Creación  -->
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                            Text="{Binding FechaCreacion, Converter={StaticResource DateTimeFormatConverter}}" />
                                    </StackPanel>

                                    <!--  Delete Button  -->
                                    <Button
                                        Grid.Column="1" Padding="8" VerticalAlignment="Top" Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.EliminarNotificacionCommand, ElementName=RootGrid}"
                                        CommandParameter="{Binding Id}"
                                        ToolTipService.ToolTip="Eliminar notificación">
                                        <SymbolIcon Symbol="Delete" />
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Separador silenciadas -->
            <Border
                Grid.Row="2"
                Margin="0,8,0,4"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1" />

            <!-- Sección: Notificaciones silenciadas -->
            <StackPanel Grid.Row="3" Spacing="6">
                <TextBlock
                    FontSize="12" FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Silenciadas" />
                <ItemsRepeater x:Name="SilenciadasRepeater" ItemsSource="{Binding NotificacionesSilenciadas}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="4" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate xmlns:models="using:Advance_Control.Models" x:DataType="models:NotificacionSilenciadaVm">
                            <Border
                                Padding="8,6" CornerRadius="4"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        FontSize="12"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind Label}"
                                        TextTrimming="CharacterEllipsis" />
                                    <ToggleSwitch
                                        Grid.Column="1"
                                        MinWidth="0" Margin="4,0,0,0"
                                        OnContent="" OffContent=""
                                        IsOn="{x:Bind Habilitada, Mode=TwoWay}"
                                        Toggled="SilenciadaToggle_Toggled"
                                        Tag="{x:Bind Categoria}"
                                        ToolTipService.ToolTip="Reactivar notificaciones de esta categoría" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </Grid>
        <Grid
            Grid.Row="1" Grid.ColumnSpan="2" Padding="12,0"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" Fill="{ThemeResource SystemFillColorSuccessBrush}" />
                <TextBlock FontSize="11" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="En línea" />
            </StackPanel>
        </Grid>
    </Grid>


</Window>
