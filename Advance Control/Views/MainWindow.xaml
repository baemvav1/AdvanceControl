<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Advance_Control.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Advance_Control"
    xmlns:views="using:Advance_Control.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Advance Control"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="8*" />
            <ColumnDefinition x:Name="NotificacionesColumn" Width="0" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <!--  Barra de título personalizada (drag region + botones nativos del sistema a la derecha)  -->
        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Height="36"
            Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <!--  Espacio reservado para los botones nativos min/max/close (≈138 px)  -->
                <ColumnDefinition Width="138" />
            </Grid.ColumnDefinitions>
            <StackPanel
                Grid.Column="0"
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <FontIcon
                    FontSize="14"
                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                    Glyph="&#xE7EE;" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Advance Control" />
            </StackPanel>
            <!--  Zona arrastrable  -->
            <Grid
                x:Name="AppTitleBarDragRegion"
                Grid.Column="1"
                Background="Transparent" />
        </Grid>

        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid x:Name="TopBar" Grid.Row="0">
                <Grid Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <!--  Botón login/logout con PersonPicture  -->
                        <StackPanel
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="8">
                            <Button
                                x:Name="LogIn"
                                Width="36"
                                Height="36"
                                Padding="0"
                                VerticalAlignment="Center"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                Click="LoginButton_Click"
                                CornerRadius="5,0,5,0"
                                ToolTipService.ToolTip="Cuenta de usuario">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{ThemeResource AccentAAFillColorDisabled}" />
                                </Button.Resources>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="{Binding UserInitials}" />
                            </Button>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                Text="{Binding UserType}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Column="1">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="15"
                            FontWeight="Bold"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            Text="{Binding Title}" />
                    </Grid>

                    <Grid Grid.Column="2">
                        <Button
                            x:Name="ToggleChatButton"
                            Width="36"
                            Height="36"
                            Margin="0,0,5,0"
                            Padding="0"
                            HorizontalAlignment="Right"
                            Click="ToggleChat_Click"
                            CornerRadius="5,0,5,0"
                            ToolTipService.ToolTip="Chat">
                            <FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Glyph="&#xE8BD;" />
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
            <Grid Grid.Row="1">
                <NavigationView
                    x:Name="nvSample"
                    IsBackButtonVisible="Collapsed"
                    IsBackEnabled="{Binding IsBackEnabled, Mode=OneWay}"
                    IsPaneOpen="False">
                    <NavigationView.MenuItems>
                        <NavigationViewItem
                            Background="{ThemeResource ControlElevationBorderBrush}"
                            Content="Inicio"
                            Tag="Inicio">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE80F;" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <!--  Grupo: Negocios  -->
                        <NavigationViewItem
                            Background="{ThemeResource ControlElevationBorderBrush}"
                            Content="Operaciones"
                            IsExpanded="True"
                            SelectsOnInvoked="False">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE822;" />
                            </NavigationViewItem.Icon>
                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem Content="Operaciones" Tag="Operaciones">
                                    <NavigationViewItem.Icon>
                                        <FontIcon Glyph="&#xE9F5;" />
                                    </NavigationViewItem.Icon>
                                </NavigationViewItem>
                                <!--
                                    NavigationViewItem
                                    Content="Asesoría" Icon="ContactInfo" Tag="Asesoria" /
                                -->
                                <NavigationViewItem
                                    Content="Orden de Servicio"
                                    Icon="Repair"
                                    Tag="OrdenServicio" />
                                <NavigationViewItem Content="Levantamientos" Tag="Levantamientos">
                                    <NavigationViewItem.Icon>
                                        <FontIcon Glyph="&#xE8FF;" />
                                    </NavigationViewItem.Icon>
                                </NavigationViewItem>
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                        <!--  Grupo: Clientes  -->
                        <NavigationViewItem
                            Background="{ThemeResource ControlElevationBorderBrush}"
                            Content="Clientes"
                            IsExpanded="True"
                            SelectsOnInvoked="False">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE716;" />
                            </NavigationViewItem.Icon>
                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem Content="Clientes" Tag="Clientes">
                                    <NavigationViewItem.Icon>
                                        <FontIcon Glyph="&#xE902;" />
                                    </NavigationViewItem.Icon>
                                </NavigationViewItem>
                                <NavigationViewItem
                                    Content="Contactos"
                                    Icon="Contact"
                                    Tag="Contactos" />
                                <NavigationViewItem Content="Entidades" Tag="Entidades">
                                    <NavigationViewItem.Icon>
                                        <FontIcon Glyph="&#xE8C7;" />
                                    </NavigationViewItem.Icon>
                                </NavigationViewItem>
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                        <!--  Grupo: Catálogos  -->
                        <NavigationViewItem
                            Background="{ThemeResource ControlElevationBorderBrush}"
                            Content="Catálogos"
                            Icon="Library"
                            IsExpanded="True"
                            SelectsOnInvoked="False">

                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem
                                    Content="Equipos"
                                    Icon="AllApps"
                                    Tag="Equipos" />
                                <NavigationViewItem
                                    Content="Refacciones"
                                    Icon="Setting"
                                    Tag="Refacciones" />
                                <NavigationViewItem Content="Servicios" Tag="Servicios">
                                    <NavigationViewItem.Icon>
                                        <FontIcon Glyph="&#xEC7A;" />
                                    </NavigationViewItem.Icon>
                                </NavigationViewItem>
                                <NavigationViewItem
                                    Content="Proveedores"
                                    Icon="Contact"
                                    Tag="Proveedores" />
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                        <!--  Grupo: Ubicaciones  -->
                        <NavigationViewItem
                            Background="{ThemeResource ControlElevationBorderBrush}"
                            Content="Ubicaciones"
                            IsExpanded="True"
                            SelectsOnInvoked="False">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE913;" />
                            </NavigationViewItem.Icon>
                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem
                                    Content="Ubicaciones"
                                    Icon="MapPin"
                                    Tag="Ubicaciones" />
                                <NavigationViewItem
                                    Content="Áreas"
                                    Icon="Map"
                                    Tag="Areas" />
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                        <!--  Grupo: Financiero  -->
                        <NavigationViewItem
                            Background="{ThemeResource ControlElevationBorderBrush}"
                            Content="Financiero"
                            IsExpanded="True"
                            SelectsOnInvoked="False">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE825;" />
                            </NavigationViewItem.Icon>
                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem Content="Estado de Cuenta" Tag="EstadoCuenta">
                                    <NavigationViewItem.Icon>
                                        <FontIcon Glyph="&#xEAFC;" />
                                    </NavigationViewItem.Icon>
                                </NavigationViewItem>
                                <NavigationViewItem
                                    Content="Conciliación"
                                    Icon="Switch"
                                    Tag="Conciliacion" />
                                <NavigationViewItem
                                    Content="Facturas"
                                    Icon="Document"
                                    Tag="Facturas" />
                                <!--  ReportHacked  -->
                                <NavigationViewItem Content="Reporte Facturación" Tag="ReporteFinancieroFacturacion">
                                    <NavigationViewItem.Icon>
                                        <FontIcon Glyph="&#xE9F9;" />
                                    </NavigationViewItem.Icon>
                                </NavigationViewItem>
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                        <!--  Grupo: Correo  -->
                        <NavigationViewItem
                            Background="{ThemeResource ControlElevationBorderBrush}"
                            Content="Comunicación"
                            IsExpanded="True"
                            SelectsOnInvoked="False">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE715;" />
                            </NavigationViewItem.Icon>
                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem Content="Mensajes" Tag="Mensajes">
                                    <NavigationViewItem.Icon>
                                        <FontIcon Glyph="&#xE8BD;" />
                                    </NavigationViewItem.Icon>
                                </NavigationViewItem>
                                <NavigationViewItem
                                    Content="Configuración Correo"
                                    Icon="Setting"
                                    Tag="Correo" />
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                        <!--  Grupo: Administración  -->
                        <NavigationViewItem
                            Background="{ThemeResource ControlElevationBorderBrush}"
                            Content="Administración"
                            IsExpanded="True"
                            SelectsOnInvoked="False">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE7EF;" />
                            </NavigationViewItem.Icon>
                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem
                                    Content="Administración"
                                    Icon="Setting"
                                    Tag="Administracion" />
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                        <!--  Grupo: DevOps  -->
                        <NavigationViewItem
                            Background="{ThemeResource ControlElevationBorderBrush}"
                            Content="DevOps"
                            Icon="ReportHacked"
                            IsExpanded="True">
                            <NavigationViewItem.MenuItems>
                                <NavigationViewItem
                                    Content="Herramientas"
                                    Icon="Repair"
                                    SelectsOnInvoked="False"
                                    Tag="DevOps" />
                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                    </NavigationView.MenuItems>
                    <Frame x:Name="contentFrame" />
                </NavigationView>
            </Grid>

        </Grid>
        <Grid
            x:Name="ChatPanel"
            Grid.Row="1"
            Grid.Column="1"
            Padding="0"
            Visibility="{Binding IsChatPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <views:ChatPanelView x:Name="ChatPanelControl" Visibility="Visible" />
            <views:UsuarioInfoView x:Name="UsuarioInfoControl" Visibility="Collapsed" />
        </Grid>
        <Grid
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Padding="12,0"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="6">
                <Ellipse
                    Width="8"
                    Height="8"
                    Fill="{ThemeResource SystemFillColorSuccessBrush}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="En línea" />
            </StackPanel>
        </Grid>

        <!--  InfoBar de notificación in-app (fallback cuando no hay MSIX desplegado)  -->
        <InfoBar
            x:Name="NotificacionInfoBar"
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Canvas.ZIndex="10"
            MaxWidth="420"
            Margin="0,8,16,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            IsClosable="True"
            IsOpen="False" />
    </Grid>


</Window>
