<Window
    x:Class="Advance_Control.Views.Windows.ConfirmacionConciliacionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialogs="using:Advance_Control.Views.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Barra de filtro  -->
        <StackPanel Orientation="Horizontal">
            <Border
                Grid.Row="0"
                Padding="20,14,20,10"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
                <TextBox
                    x:Name="TxtFiltroMetadato"
                    Width="420"
                    HorizontalAlignment="Left"
                    PlaceholderText="Filtrar por metadato del movimiento..."
                    TextChanged="TxtFiltroMetadato_TextChanged" />
            </Border>
            
        </StackPanel>

        <!--  Contenido: UserControl con la tabla de propuestas  -->
        <ScrollViewer 
            Grid.Row="1"
            Padding="20,12,20,0"
            VerticalScrollBarVisibility="Auto">
            <dialogs:ConfirmacionConciliacionUserControl x:Name="ControlConfirmacion" />
        </ScrollViewer>

        <!--  Footer con botones  -->
        <Border
            Grid.Row="2"
            Padding="20,12"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Name="TxtResumen"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        x:Name="BtnCancelar"
                        Click="BtnCancelar_Click"
                        Content="Cancelar" />
                    <Button
                        x:Name="BtnConfirmar"
                        Click="BtnConfirmar_Click"
                        Content="Confirmar seleccionadas"
                        Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
