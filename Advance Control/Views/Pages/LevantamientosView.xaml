<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Advance_Control.Views.Pages.LevantamientosView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lev="using:Advance_Control.Services.Levantamiento">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock
                FontSize="28"
                FontWeight="SemiBold"
                Text="Levantamientos" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Gestion de levantamientos de equipos" />
        </StackPanel>

        <!--  Toolbar  -->
        <StackPanel
            Grid.Row="1"
            Margin="0,16,0,12"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                x:Name="NuevoLevantamientoButton"
                Click="NuevoLevantamiento_Click"
                Style="{ThemeResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE710;" />
                    <TextBlock Text="Nuevo levantamiento" />
                </StackPanel>
            </Button>
            <Button
                x:Name="RefrescarButton"
                Click="Refrescar_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                    <TextBlock Text="Refrescar" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!--  Loading  -->
        <ProgressRing
            Grid.Row="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

        <!--  Empty state  -->
        <TextBlock
            Grid.Row="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="14"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="No hay levantamientos registrados"
            Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

        <!--  List  -->
        <ScrollViewer Grid.Row="2">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Levantamientos, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="8" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="lev:LevantamientoListItemResponse">
                        <Border
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  ID badge  -->
                                <Border
                                    Grid.Column="0"
                                    Width="50"
                                    Height="50"
                                    Background="{ThemeResource SystemAccentColorDark2}"
                                    CornerRadius="8">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="{x:Bind IdLevantamiento}" />
                                </Border>

                                <!--  Info  -->
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                                    <TextBlock FontSize="15" FontWeight="SemiBold">
                                        <Run Text="Equipo: " />
                                        <Run Text="{x:Bind EquipoIdentificador}" />
                                    </TextBlock>
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="Marca: " />
                                        <Run Text="{x:Bind EquipoMarca}" />
                                        <Run Text="  ·  " />
                                        <Run Text="{x:Bind TipoConfiguracion}" />
                                    </TextBlock>
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Text="{x:Bind FechaCreacion}" />
                                    <TextBlock
                                        MaxLines="1"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind Introduccion}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <!--  Buttons  -->
                                <StackPanel
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="4">
                                    <Button
                                        Click="AbrirLevantamiento_Click"
                                        Tag="{x:Bind}"
                                        ToolTipService.ToolTip="Abrir levantamiento">
                                        <FontIcon FontSize="16" Glyph="&#xE8A7;" />
                                    </Button>
                                    <Button
                                        Click="AbrirReporte_Click"
                                        Tag="{x:Bind}"
                                        ToolTipService.ToolTip="Abrir reporte PDF">
                                        <FontIcon FontSize="16" Glyph="&#xE8A5;" />
                                    </Button>
                                    <Button
                                        Click="EliminarLevantamiento_Click"
                                        Tag="{x:Bind}"
                                        ToolTipService.ToolTip="Eliminar levantamiento">
                                        <FontIcon
                                            FontSize="16"
                                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                            Glyph="&#xE74D;" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
</Page>
