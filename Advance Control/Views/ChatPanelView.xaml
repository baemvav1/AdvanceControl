<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Advance_Control.Views.ChatPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:items="using:Advance_Control.Views.Items.Mensajeria"
    xmlns:models="using:Advance_Control.Models"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource LayerFillColorDefaultBrush}"
          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header: Estado + botón colapsar usuarios  -->
        <Grid Grid.Row="0" Padding="12,8" Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                <TextBlock FontSize="14" FontWeight="SemiBold" Text="Chat" />
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Ellipse Width="6" Height="6"
                             Fill="{x:Bind GetConnectionColor(ViewModel.EstaConectado), Mode=OneWay}" />
                    <TextBlock FontSize="10"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind ViewModel.EstadoConexion, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="1" Width="30" Height="30" Padding="0"
                    Click="ToggleUserList_Click"
                    ToolTipService.ToolTip="Mostrar/ocultar usuarios">
                <FontIcon FontSize="12" Glyph="&#xE700;" />
            </Button>
        </Grid>

        <!--  Área de conversación  -->
        <Grid Grid.Row="2"
              Visibility="{x:Bind ViewModel.IsUserListVisible, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert, Mode=OneWay}">
            <!--  Header de conversación activa  -->
            <Grid Visibility="{x:Bind ViewModel.HayUsuarioSeleccionado, Mode=OneWay}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="10,6"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Width="28" Height="28" Margin="0,0,8,0">
                            <Ellipse Width="28" Height="28"
                                     Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="10" FontWeight="SemiBold" Foreground="White"
                                       Text="{x:Bind GetUsuarioIniciales(ViewModel.UsuarioSeleccionado), Mode=OneWay}" />
                        </Grid>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock FontSize="12" FontWeight="SemiBold"
                                       Text="{x:Bind GetUsuarioNombre(ViewModel.UsuarioSeleccionado), Mode=OneWay}" />
                            <TextBlock FontSize="10" Foreground="#10B981" Text="En línea"
                                       Visibility="{x:Bind GetUsuarioEnLineaVisibility(ViewModel.UsuarioSeleccionado), Mode=OneWay}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Lista de mensajes  -->
                <ListView
                    x:Name="MensajesListView"
                    Grid.Row="1"
                    Padding="8,4"
                    AllowDrop="True"
                    DragOver="ChatArea_DragOver"
                    Drop="ChatArea_Drop"
                    ItemsSource="{x:Bind ViewModel.Mensajes, Mode=OneWay}"
                    SelectionMode="None">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel ItemsUpdatingScrollMode="KeepLastItemInView" VerticalAlignment="Bottom" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0,1" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:MensajeDto">
                            <items:MensajeBurbujaItemView
                                CrearTareaClick="Burbuja_CrearTareaClick"
                                EliminarParaMiClick="Burbuja_EliminarParaMiClick"
                                EliminarParaTodosClick="Burbuja_EliminarParaTodosClick"
                                OperacionReferenciaClick="BurbujaOperacionReferencia_Click"
                                PdfButtonClick="BurbujaPdfButton_Click"
                                ResponderClick="Burbuja_ResponderClick"
                                RespuestaCitaClick="Burbuja_RespuestaCitaClick" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!--  Cargando  -->
                <ProgressRing
                    Grid.Row="1" Width="30" Height="30"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    IsActive="{x:Bind ViewModel.Cargando, Mode=OneWay}" />
            </Grid>

        </Grid>

        <!--  Barra de entrada de texto + preview de respuesta  -->
        <StackPanel Grid.Row="3"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    Visibility="{x:Bind ViewModel.MostrarBarraEntrada, Mode=OneWay}">
            <Grid Padding="8,4"
                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                  ColumnSpacing="6"
                  Visibility="{x:Bind ViewModel.MostrarPreviewRespuesta, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{ThemeResource AccentFillColorDefaultBrush}" />
                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                    <TextBlock FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}">
                        <Run Text="Respondiendo a " />
                        <Run Text="{x:Bind ViewModel.RespuestaAutor, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind ViewModel.RespuestaResumen, Mode=OneWay}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap" />
                </StackPanel>
                <Button Grid.Column="2"
                        Width="28" Height="28"
                        Background="Transparent"
                        Click="CancelarRespuesta_Click"
                        ToolTipService.ToolTip="Cancelar respuesta">
                    <FontIcon FontSize="12" Glyph="&#xE711;" />
                </Button>
            </Grid>
            <Grid Padding="8,6"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                  BorderThickness="0,1,0,0"
                  ColumnSpacing="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Width="40" Height="40"
                        Click="AdjuntarButton_Click"
                        CornerRadius="16"
                        IsEnabled="{x:Bind ViewModel.EstaConectado, Mode=OneWay}"
                        ToolTipService.ToolTip="Adjuntar archivo">
                    <FontIcon FontSize="13" Glyph="&#xE7C5;" />
                </Button>
                <TextBox
                    x:Name="MensajeTextBox"
                    Grid.Column="1"
                    MaxHeight="80"
                    AcceptsReturn="False"
                    KeyDown="MensajeTextBox_KeyDown"
                    PlaceholderText="Escribe un mensaje…"
                    Text="{x:Bind ViewModel.TextoMensaje, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextChanged="MensajeTextBox_TextChanged"
                    TextWrapping="Wrap"
                    FontSize="12" />
                <Button Grid.Column="2" Width="40" Height="40"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        Click="EnviarButton_Click"
                        CornerRadius="16"
                        IsEnabled="{x:Bind ViewModel.EstaConectado, Mode=OneWay}"
                        ToolTipService.ToolTip="Enviar">
                    <FontIcon FontSize="13" Foreground="White" Glyph="&#xE724;" />
                </Button>
            </Grid>
        </StackPanel>

        <!--  Indicador de subida  -->
        <StackPanel Grid.Row="3"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Orientation="Horizontal" Spacing="6"
                    Visibility="{x:Bind ViewModel.EnviandoImagen, Mode=OneWay}">
            <ProgressRing Width="16" Height="16" IsActive="{x:Bind ViewModel.EnviandoImagen, Mode=OneWay}" />
            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Enviando…" />
        </StackPanel>

        <!--  Lista de usuarios (alterna con el área de conversación)  -->
        <Grid Grid.Row="2"
              Grid.RowSpan="2"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              Visibility="{x:Bind ViewModel.IsUserListVisible, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Padding="12,10,12,8" Spacing="8">
                <StackPanel Spacing="2">
                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="Contactos" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Selecciona un usuario para conversar" />
                </StackPanel>

                <AutoSuggestBox
                    x:Name="BuscadorUsuarios"
                    PlaceholderText="Buscar usuario…"
                    QueryIcon="Find"
                    TextChanged="BuscadorUsuarios_TextChanged" />
            </StackPanel>

            <ListView
                x:Name="UsuariosListView"
                Grid.Row="1"
                Margin="4,0,4,8"
                Background="Transparent"
                BorderThickness="0"
                ItemsSource="{x:Bind ViewModel.Usuarios, Mode=OneWay}"
                SelectionChanged="UsuariosListView_SelectionChanged"
                SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:UsuarioChatDto">
                        <items:UsuarioChatItemView />
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Margin" Value="4,2" />
                        <Setter Property="Padding" Value="6,4" />
                        <Setter Property="MinHeight" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Grid>
    </Grid>
</UserControl>
