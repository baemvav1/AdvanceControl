<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Advance_Control.Views.Pages.ConciliacionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:items="using:Advance_Control.Views.Items.Conciliacion"
    xmlns:local="using:Advance_Control.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Advance_Control.Models"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="280" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" MinWidth="280" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="220" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" MinHeight="180" />
        </Grid.RowDefinitions>
        <Grid
            x:Name="Movimientos"
            Grid.Row="0"
            Grid.Column="2">
            <Border
                Margin="5"
                Padding="5"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="2"
                CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>
                    <Grid x:Name="MovimientosHeader" Grid.Row="0">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="24"
                            Text="Movimientos" />
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid
                                Grid.Row="0"
                                ColumnSpacing="12"
                                RowSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="160" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding ResumenMovimientos}" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Solo se muestran movimientos pendientes de conciliacion." />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Metadato" />
                                    <TextBox PlaceholderText="Buscar texto..." Text="{x:Bind ViewModel.MovimientoMetadatoBusquedaTexto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="Abono" />
                                    <TextBox PlaceholderText="Ej. 1250" Text="{x:Bind ViewModel.MovimientoAbonoBusquedaTexto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <ScrollViewer Grid.Row="1">
                                <muxc:ItemsRepeater ItemsSource="{Binding MovimientosPendientes}">
                                    <muxc:ItemsRepeater.Layout>
                                        <muxc:StackLayout Spacing="8" />
                                    </muxc:ItemsRepeater.Layout>
                                    <muxc:ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <Button
                                                Padding="0"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="MovimientoPendienteButton_Click"
                                                Tag="{Binding}">
                                                <items:ConciliacionMovimientoItemView Movimiento="{Binding}" />
                                            </Button>
                                        </DataTemplate>
                                    </muxc:ItemsRepeater.ItemTemplate>
                                </muxc:ItemsRepeater>
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                </Grid>
            </Border>

        </Grid>
        <Border
            x:Name="MovimientosResizeHandle"
            Grid.Row="0"
            Grid.Column="1"
            Width="8"
            Background="{ThemeResource CardStrokeColorDefaultBrush}"
            PointerCanceled="MovimientosResizeHandle_PointerCanceled"
            PointerCaptureLost="MovimientosResizeHandle_PointerCaptureLost"
            PointerMoved="MovimientosResizeHandle_PointerMoved"
            PointerPressed="MovimientosResizeHandle_PointerPressed"
            PointerReleased="MovimientosResizeHandle_PointerReleased" />
        <Grid
            x:Name="Facturas"
            Grid.Row="0"
            Grid.Column="0">
            <Border
                Margin="5"
                Padding="5"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="2"
                CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="24"
                            Text="Facturas" />
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid
                                Grid.Row="0"
                                ColumnSpacing="12"
                                RowSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="240" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding ResumenFacturas}" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Solo se muestran facturas abiertas o con saldo pendiente." />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Filtro directo" />
                                    <TextBox PlaceholderText="Buscar folio..." Text="{x:Bind ViewModel.FacturaFolioBusquedaTexto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <ScrollViewer Grid.Row="1">
                                <muxc:ItemsRepeater ItemsSource="{Binding FacturasPendientes}">
                                    <muxc:ItemsRepeater.Layout>
                                        <muxc:StackLayout Spacing="8" />
                                    </muxc:ItemsRepeater.Layout>
                                    <muxc:ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <Button
                                                Padding="0"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="FacturaPendienteButton_Click"
                                                Tag="{Binding}">
                                                <items:ConciliacionFacturaItemView Factura="{Binding}" />
                                            </Button>
                                        </DataTemplate>
                                    </muxc:ItemsRepeater.ItemTemplate>
                                </muxc:ItemsRepeater>
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                </Grid>
            </Border>
        </Grid>
        <Border
            x:Name="ConciliacionResizeHandle"
            Grid.Row="1"
            Grid.ColumnSpan="3"
            Height="8"
            Background="{ThemeResource CardStrokeColorDefaultBrush}"
            PointerCanceled="ConciliacionResizeHandle_PointerCanceled"
            PointerCaptureLost="ConciliacionResizeHandle_PointerCaptureLost"
            PointerMoved="ConciliacionResizeHandle_PointerMoved"
            PointerPressed="ConciliacionResizeHandle_PointerPressed"
            PointerReleased="ConciliacionResizeHandle_PointerReleased" />
        <Grid
            x:Name="Conciliacion"
            Grid.Row="2"
            Grid.ColumnSpan="3">
            <Border
                Margin="5"
                Padding="5"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="2"
                CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>
                    <Grid x:Name="ConciliacionHeader" Grid.Row="0">
                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                            <Button
                                x:Name="BtnConciliacionAutomatica"
                                Margin="5,0,0,0"
                                Click="BtnConciliacionAutomatica_Click"
                                Content="Conciliacion Automatica" />
                            <Button
                                x:Name="BtnConciliacionAutomaticaAbonos"
                                Margin="5,0,0,0"
                                Click="BtnConciliacionAutomaticaAbonos_Click"
                                Content="Conciliacion Automatica de Abonos" />
                            <Button
                                Grid.Column="1"
                                Margin="0,0,4,0"
                                Click="BtnAbonarMovimientoCargado_Click"
                                Content="Abonar"
                                IsEnabled="{Binding CanAbonarMovimiento}" />
                            <Button
                                Grid.Column="1"
                                Margin="0,0,4,0"
                                Click="BtnLimpiarMovimientoCargado_Click"
                                Content="Limpiar" />
                        </StackPanel>
                    </Grid>
                    <Grid x:Name="ConciliacionPanelGrid" Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="260" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" MinWidth="260" />
                        </Grid.ColumnDefinitions>
                        <Border
                            x:Name="FacturaCargada"
                            Grid.Column="0"
                            Margin="1"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="2"
                            CornerRadius="8">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Padding="12" Spacing="12">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="{Binding MensajeFacturaCargada}"
                                        TextWrapping="Wrap" />

                                    <Grid ColumnSpacing="12" RowSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            FontWeight="SemiBold"
                                            Text="UUID:" />
                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            Text="{Binding FacturaCargadaUuidTexto}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            FontWeight="SemiBold"
                                            Text="Fecha:" />
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Text="{Binding FacturaCargadaFechaTexto}" />
                                        <TextBlock
                                            Grid.Row="2"
                                            Grid.Column="0"
                                            FontWeight="SemiBold"
                                            Text="Emisor:" />
                                        <TextBlock
                                            Grid.Row="2"
                                            Grid.Column="1"
                                            Text="{Binding FacturaCargadaEmisorTexto}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            Grid.Row="3"
                                            Grid.Column="0"
                                            FontWeight="SemiBold"
                                            Text="Receptor:" />
                                        <TextBlock
                                            Grid.Row="3"
                                            Grid.Column="1"
                                            Text="{Binding FacturaCargadaReceptorTexto}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            Grid.Row="4"
                                            Grid.Column="0"
                                            FontWeight="SemiBold"
                                            Text="RFCs:" />
                                        <TextBlock
                                            Grid.Row="4"
                                            Grid.Column="1"
                                            Text="{Binding FacturaCargadaRfcTexto}"
                                            TextWrapping="Wrap" />
                                    </Grid>

                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border
                                            Grid.Column="0"
                                            Padding="8"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                            <StackPanel Spacing="4">
                                                <TextBlock FontWeight="SemiBold" Text="Estado" />
                                                <TextBlock Text="{Binding FacturaCargadaEstadoPagoTexto}" />
                                            </StackPanel>
                                        </Border>

                                        <Border
                                            Grid.Column="1"
                                            Padding="8"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                            <StackPanel Spacing="4">
                                                <TextBlock FontWeight="SemiBold" Text="Abonado" />
                                                <TextBlock Text="{Binding FacturaCargadaTotalAbonadoTexto}" />
                                            </StackPanel>
                                        </Border>

                                        <Border
                                            Grid.Column="2"
                                            Padding="8"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                            <StackPanel Spacing="4">
                                                <TextBlock FontWeight="SemiBold" Text="Saldo pendiente" />
                                                <TextBlock Text="{Binding FacturaCargadaSaldoPendienteTexto}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding FacturaCargadaMetodoFormaTexto}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding FacturaCargadaTotalesTexto}"
                                        TextWrapping="Wrap" />

                                    <StackPanel Spacing="8">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding ResumenFacturaCargadaConceptos}" />
                                        <ListView ItemsSource="{Binding FacturaCargadaConceptos}" SelectionMode="None">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Margin="0,0,0,6"
                                                        Padding="8"
                                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock
                                                                FontWeight="SemiBold"
                                                                Text="{Binding Descripcion}"
                                                                TextWrapping="Wrap" />
                                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding ClavesTexto}" />
                                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding ImporteTexto}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding ResumenFacturaCargadaAbonos}" />
                                        <ListView ItemsSource="{Binding FacturaCargadaAbonos}" SelectionMode="None">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Margin="0,0,0,6"
                                                        Padding="8"
                                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock FontWeight="SemiBold" Text="{Binding MontoAbonoTexto}" />
                                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding FechaAbonoTexto}" />
                                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding MovimientoTexto}" />
                                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding ReferenciaTexto}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                        <Border
                            x:Name="FacturaAbonoResizeHandle"
                            Grid.Column="1"
                            Width="8"
                            Background="{ThemeResource CardStrokeColorDefaultBrush}"
                            PointerCanceled="FacturaAbonoResizeHandle_PointerCanceled"
                            PointerCaptureLost="FacturaAbonoResizeHandle_PointerCaptureLost"
                            PointerMoved="FacturaAbonoResizeHandle_PointerMoved"
                            PointerPressed="FacturaAbonoResizeHandle_PointerPressed"
                            PointerReleased="FacturaAbonoResizeHandle_PointerReleased" />

                        <Grid x:Name="Abono" Grid.Column="2">
                            <Border
                                x:Name="MovimientoCargado"
                                Margin="1"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="2"
                                CornerRadius="8">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Padding="12" Spacing="12">
                                        <TextBlock
                                            FontWeight="SemiBold"
                                            Text="{Binding MensajeMovimientoCargado}"
                                            TextWrapping="Wrap" />

                                        <Grid ColumnSpacing="12" RowSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock
                                                Grid.Row="0"
                                                Grid.Column="0"
                                                FontWeight="SemiBold"
                                                Text="Cuenta:" />
                                            <TextBlock
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                Text="{Binding MovimientoCargadoCuentaTexto}"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                Grid.Row="1"
                                                Grid.Column="0"
                                                FontWeight="SemiBold"
                                                Text="Banco / titular:" />
                                            <TextBlock
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Text="{Binding MovimientoCargadoBancoTexto}"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                Grid.Row="2"
                                                Grid.Column="0"
                                                FontWeight="SemiBold"
                                                Text="Periodo:" />
                                            <TextBlock
                                                Grid.Row="2"
                                                Grid.Column="1"
                                                Text="{Binding MovimientoCargadoPeriodoTexto}" />
                                            <TextBlock
                                                Grid.Row="3"
                                                Grid.Column="0"
                                                FontWeight="SemiBold"
                                                Text="Fecha:" />
                                            <TextBlock
                                                Grid.Row="3"
                                                Grid.Column="1"
                                                Text="{Binding MovimientoCargadoFechaTexto}" />
                                            <TextBlock
                                                Grid.Row="4"
                                                Grid.Column="0"
                                                FontWeight="SemiBold"
                                                Text="Referencia:" />
                                            <TextBlock
                                                Grid.Row="4"
                                                Grid.Column="1"
                                                Text="{Binding MovimientoCargadoReferenciaTexto}"
                                                TextWrapping="Wrap" />
                                        </Grid>

                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border
                                                Grid.Column="0"
                                                Padding="8"
                                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                                <StackPanel Spacing="4">
                                                    <TextBlock FontWeight="SemiBold" Text="Cargo" />
                                                    <TextBlock Text="{Binding MovimientoCargadoCargoTexto}" />
                                                </StackPanel>
                                            </Border>

                                            <Border
                                                Grid.Column="1"
                                                Padding="8"
                                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                                <StackPanel Spacing="4">
                                                    <TextBlock FontWeight="SemiBold" Text="Abono" />
                                                    <TextBlock Text="{Binding MovimientoCargadoAbonoTexto}" />
                                                </StackPanel>
                                            </Border>

                                            <Border
                                                Grid.Column="2"
                                                Padding="8"
                                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                                <StackPanel Spacing="4">
                                                    <TextBlock FontWeight="SemiBold" Text="Saldo" />
                                                    <TextBlock Text="{Binding MovimientoCargadoSaldoTexto}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding MovimientoCargadoRelacionadosTexto}"
                                            TextWrapping="Wrap" />

                                        <Border
                                            Padding="10"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                            <StackPanel Spacing="4">
                                                <TextBlock FontWeight="SemiBold" Text="Metadatos" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{Binding MovimientoCargadoMetadatosTexto}"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>

                    </Grid>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>


