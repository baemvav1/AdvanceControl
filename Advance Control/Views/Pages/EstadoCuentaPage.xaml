<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Advance_Control.Views.Pages.EstadoCuentaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Advance_Control.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
            <TextBlock Text="Estados de Cuenta"
                       Style="{StaticResource TitleTextBlockStyle}"
                       VerticalAlignment="Center"/>
            <Button x:Name="BtnCargarXml"
                     Content="Cargar Archivo XML"
                     Click="BtnCargarXml_Click"
                     IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"/>
            <Button x:Name="BtnActualizarListado"
                    Content="Actualizar listado"
                    Click="BtnActualizarListado_Click"
                    IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ProgressRing Grid.Column="0"
                          IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="40" Height="40"
                          Margin="0,0,0,10"/>

            <StackPanel Grid.Column="1">
                <InfoBar x:Name="ErrorInfoBar"
                         IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}"
                         Severity="Error"
                         Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                         IsClosable="True"/>

                <InfoBar x:Name="SuccessInfoBar"
                         IsOpen="{x:Bind ViewModel.SuccessMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}"
                         Severity="Success"
                         Message="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"
                         IsClosable="True"
                         Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <Border Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="16">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Estados de cuenta existentes"
                                   Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock Text="Selecciona un estado para abrir su detalle."
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Margin="0,4,0,0"/>
                        <TextBlock Text="{x:Bind ViewModel.ResumenEstadosExistentes, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Filtros"
                                        FontWeight="SemiBold"/>
                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Row="0"
                                         Grid.Column="0"
                                         PlaceholderText="Buscar por abono"
                                         Text="{x:Bind ViewModel.AbonoFiltro, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBox Grid.Row="0"
                                         Grid.Column="1"
                                         PlaceholderText="Buscar por retiro"
                                         Text="{x:Bind ViewModel.RetiroFiltro, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBox Grid.Row="0"
                                         Grid.Column="2"
                                         PlaceholderText="Buscar por referencia"
                                         Text="{x:Bind ViewModel.ReferenciaFiltro, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <CalendarDatePicker Grid.Row="1"
                                                    Grid.Column="0"
                                                    Header="Desde"
                                                    Date="{x:Bind ViewModel.FechaFiltroDesde, Mode=TwoWay}"/>

                                <CalendarDatePicker Grid.Row="1"
                                                    Grid.Column="1"
                                                    Header="Hasta"
                                                    Date="{x:Bind ViewModel.FechaFiltroHasta, Mode=TwoWay}"/>

                                <Button Grid.Row="1"
                                        Grid.Column="5"
                                        Content="Limpiar"
                                        VerticalAlignment="Bottom"
                                        Click="BtnLimpiarFiltrosEstados_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <ListView Grid.Row="2"
                              x:Name="EstadosCuentaListView"
                              ItemsSource="{x:Bind ViewModel.EstadosCuentaExistentes, Mode=OneWay}"
                              IsItemClickEnabled="True"
                              SelectionMode="None"
                              ItemClick="EstadosCuentaListView_ItemClick"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                              BorderThickness="1"
                              CornerRadius="8"
                              Padding="8"
                              Background="{ThemeResource LayerFillColorDefaultBrush}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:EstadoCuentaResumenDto">
                                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="12"
                                        Margin="0,0,0,10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding CuentaTitulo}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding BancoTitularTexto}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="WrapWholeWords"/>
                                        <TextBlock Text="{Binding PeriodoTexto}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{Binding TotalesEstructuraTexto}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="WrapWholeWords"/>
                                        <TextBlock Text="{Binding SaldoFinalTexto}"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
