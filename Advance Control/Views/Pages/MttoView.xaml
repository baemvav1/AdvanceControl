<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Advance_Control.Views.MttoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Advance_Control.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Advance_Control.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToCornerRadiusConverter x:Key="BooleanToCornerRadiusConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BooleanToExpandTextConverter x:Key="BooleanToExpandTextConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,24"
            Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock
                    FontSize="32"
                    FontWeight="Bold"
                    Text="Mantenimiento" />
                <Button
                    x:Name="Nuevo"
                    VerticalAlignment="Center"
                    Click="NuevoButton_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTipService.ToolTip="Crear nuevo mantenimiento">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Add" />
                        <TextBlock VerticalAlignment="Center" Text="Nuevo" />
                    </StackPanel>
                </Button>
            </StackPanel>
            <TextBlock
                FontSize="16"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Gestión de mantenimientos del sistema" />
        </StackPanel>

        <!--  Filtros  -->
        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,16"
            Spacing="12">
            <TextBlock
                FontSize="16"
                FontWeight="SemiBold"
                Text="Filtros de búsqueda" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox
                    Grid.Column="0"
                    Margin="0,0,8,8"
                    Header="Identificador de Equipo"
                    PlaceholderText="Identificador del equipo"
                    Text="{x:Bind ViewModel.IdentificadorFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        Click="SearchButton_Click"
                        Content="Buscar"
                        Style="{StaticResource AccentButtonStyle}" />
                    <Button Click="ClearButton_Click" Content="Limpiar" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <!--  Lista de mantenimientos  -->
        <Grid Grid.Row="2">
            <!--  ItemsRepeater con ScrollViewer  -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Mantenimientos, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="0" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate xmlns:local="using:Advance_Control.Models" x:DataType="local:MantenimientoDto">
                            <Grid Margin="0,5,20,5">
                                <StackPanel Orientation="Vertical">
                                    <Grid
                                        x:Name="Head"
                                        Grid.Row="0"
                                        MinHeight="90"
                                        Padding="16"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="{x:Bind Expand, Converter={StaticResource BooleanToCornerRadiusConverter}, ConverterParameter='8,8,0,0|8', Mode=OneWay}"
                                        Tag="{x:Bind}"
                                        Tapped="HeadGrid_Tapped">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!--  Información principal del mantenimiento  -->
                                        <StackPanel Grid.Column="0" Spacing="6">
                                            <TextBlock
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Text="{x:Bind TipoMantenimiento}" />
                                            <TextBlock
                                                FontSize="14"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind Identificador}" />
                                            <StackPanel Orientation="Horizontal" Spacing="20">
                                                <TextBlock FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                    <Run Text="Cliente: " />
                                                    <Run FontWeight="SemiBold" Text="{x:Bind RazonSocial}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <!--  Botón para expandir/colapsar  -->
                                        <Button
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="ToggleExpandButton_Click"
                                            Content="{x:Bind Expand, Converter={StaticResource BooleanToExpandTextConverter}, Mode=OneWay}"
                                            Tag="{x:Bind}" />
                                    </Grid>
                                    <Grid
                                        x:Name="Body"
                                        Grid.Row="1"
                                        Padding="8"
                                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                                        CornerRadius="{x:Bind Expand, Converter={StaticResource BooleanToCornerRadiusConverter}, ConverterParameter='0,0,8,8|0', Mode=OneWay}"
                                        Visibility="{x:Bind Expand, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                        <Pivot>
                                            <!--  Información del Mantenimiento  -->
                                            <PivotItem Header="Información">
                                                <Grid Padding="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <StackPanel
                                                        Grid.Row="0"
                                                        Grid.Column="0"
                                                        Margin="0,4,0,0">
                                                        <TextBlock
                                                            FontSize="12"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            Text="ID Mantenimiento:" />
                                                        <TextBlock
                                                            FontSize="13"
                                                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                            Text="{x:Bind IdMantenimiento}" />
                                                    </StackPanel>

                                                    <StackPanel
                                                        Grid.Row="0"
                                                        Grid.Column="1"
                                                        Margin="0,4,8,0">
                                                        <TextBlock
                                                            FontSize="12"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            Text="Tipo:" />
                                                        <TextBlock
                                                            FontSize="13"
                                                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                            Text="{x:Bind TipoMantenimiento}" />
                                                    </StackPanel>

                                                    <StackPanel
                                                        Grid.Row="1"
                                                        Grid.Column="0"
                                                        Margin="0,4,0,0">
                                                        <TextBlock
                                                            FontSize="12"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            Text="Razón Social:" />
                                                        <TextBlock
                                                            FontSize="13"
                                                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                            Text="{x:Bind RazonSocial}" />
                                                    </StackPanel>

                                                    <StackPanel
                                                        Grid.Row="1"
                                                        Grid.Column="1"
                                                        Margin="0,4,8,0">
                                                        <TextBlock
                                                            FontSize="12"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            Text="Nombre Comercial:" />
                                                        <TextBlock
                                                            FontSize="13"
                                                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                            Text="{x:Bind NombreComercial}" />
                                                    </StackPanel>

                                                    <StackPanel
                                                        Grid.Row="2"
                                                        Grid.Column="0"
                                                        Margin="0,4,0,0">
                                                        <TextBlock
                                                            FontSize="12"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            Text="Identificador Equipo:" />
                                                        <TextBlock
                                                            FontSize="13"
                                                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                            Text="{x:Bind Identificador}" />
                                                    </StackPanel>


                                                    <StackPanel
                                                        Grid.Row="3"
                                                        Grid.ColumnSpan="2"
                                                        Margin="0,4,0,0">
                                                        <TextBlock
                                                            FontSize="12"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            Text="Descripcion" />
                                                        <TextBlock
                                                            FontSize="13"
                                                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                            Text="{x:Bind Descripcion}" 
                                                            Visibility="{x:Bind Descripcion, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                    </StackPanel>

                                                </Grid>
                                            </PivotItem>

                                            <!--  Acciones  -->
                                            <PivotItem Header="Acciones">
                                                <StackPanel
                                                    Padding="8"
                                                    HorizontalAlignment="Right"
                                                    Orientation="Horizontal"
                                                    Spacing="8">
                                                    <Button
                                                        AutomationProperties.Name="Atender mantenimiento"
                                                        Click="AtenderMantenimientoButton_Click"
                                                        Tag="{x:Bind}"
                                                        ToolTipService.ToolTip="Atender mantenimiento">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <SymbolIcon Symbol="Accept" />
                                                            <TextBlock Text="Atender" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button
                                                        AutomationProperties.Name="Atender como contacto"
                                                        Click="AtenderComoButton_Click"
                                                        Tag="{x:Bind}"
                                                        ToolTipService.ToolTip="Atender mantenimiento como contacto">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <SymbolIcon Symbol="ContactInfo" />
                                                            <TextBlock Text="Atender Como..." />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button
                                                        AutomationProperties.Name="Eliminar mantenimiento"
                                                        Click="DeleteMantenimientoButton_Click"
                                                        Tag="{x:Bind}"
                                                        ToolTipService.ToolTip="Eliminar mantenimiento">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <SymbolIcon Symbol="Delete" />
                                                            <TextBlock Text="Eliminar" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </PivotItem>
                                        </Pivot>
                                    </Grid>
                                </StackPanel>

                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

            <!--  Estado vacío  -->
            <StackPanel
                HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12"
                IsHitTestVisible="False"
                Visibility="{x:Bind ViewModel.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                <FontIcon Glyph="&#xE90F;" FontSize="48"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock
                    FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Sin mantenimientos" />
                <TextBlock
                    FontSize="13" HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="No se encontraron mantenimientos con los filtros actuales." />
                <Button IsHitTestVisible="True"
                    HorizontalAlignment="Center" Click="ClearButton_Click"
                    Content="Limpiar filtros" />
            </StackPanel>

            <!--  Loading overlay  -->
            <Grid
                Visibility="{x:Bind ViewModel.IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                <Rectangle Fill="{ThemeResource ApplicationPageBackgroundThemeBrush}" Opacity="0.7" />
                <ProgressRing
                    Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center"
                    IsActive="True" />
            </Grid>
        </Grid>
    </Grid>
</Page>
