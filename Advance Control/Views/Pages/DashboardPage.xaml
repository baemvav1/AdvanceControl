<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Advance_Control.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Advance_Control.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="32,28,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="28" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="28" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════
                 Hero: Bienvenida al usuario
            ══════════════════════════════════════════ -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Avatar con iniciales -->
                <Border
                    Grid.Column="0"
                    Width="72" Height="72"
                    CornerRadius="36"
                    Background="{ThemeResource AccentFillColorDefaultBrush}">
                    <TextBlock
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        FontSize="26" FontWeight="SemiBold"
                        Foreground="White"
                        Text="{x:Bind ViewModel.Iniciales, Mode=OneWay}" />
                </Border>

                <!-- Saludo y nombre -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4">
                    <TextBlock
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.FechaHoy, Mode=OneWay}" />
                    <TextBlock
                        FontSize="28" FontWeight="Bold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                        <Run Text="{x:Bind ViewModel.Saludo, Mode=OneWay}" />
                        <Run Text=", " />
                        <Run FontWeight="SemiBold"
                             Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                             Text="{x:Bind ViewModel.NombreUsuario, Mode=OneWay}" />
                        <Run Text="." />
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border
                            Padding="8,3" CornerRadius="12"
                            Background="{ThemeResource AccentFillColorTertiaryBrush}">
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                Text="{x:Bind ViewModel.TipoUsuario, Mode=OneWay}" />
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ══════════════════════════════════════════
                 Separador
            ══════════════════════════════════════════ -->
            <Border
                Grid.Row="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                VerticalAlignment="Center" />

            <!-- ══════════════════════════════════════════
                 Sección: Métricas rápidas (placeholder)
            ══════════════════════════════════════════ -->
            <StackPanel Grid.Row="2" Spacing="12">
                <TextBlock
                    FontSize="16" FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    Text="Resumen" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Tarjeta: Operaciones -->
                    <Border
                        Grid.Column="0" Padding="20,16" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE9F9;" FontSize="18"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                <TextBlock
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Operaciones" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock
                                FontSize="32" FontWeight="Bold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                Text="—" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                FontStyle="Italic"
                                Text="Próximamente" />
                        </StackPanel>
                    </Border>

                    <!-- Tarjeta: Mantenimientos -->
                    <Border
                        Grid.Column="2" Padding="20,16" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE90F;" FontSize="18"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                <TextBlock
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Mantenimientos" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock
                                FontSize="32" FontWeight="Bold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                Text="—" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                FontStyle="Italic"
                                Text="Próximamente" />
                        </StackPanel>
                    </Border>

                    <!-- Tarjeta: Clientes -->
                    <Border
                        Grid.Column="4" Padding="20,16" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE716;" FontSize="18"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                <TextBlock
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Clientes" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock
                                FontSize="32" FontWeight="Bold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                Text="—" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                FontStyle="Italic"
                                Text="Próximamente" />
                        </StackPanel>
                    </Border>

                    <!-- Tarjeta: Equipos -->
                    <Border
                        Grid.Column="6" Padding="20,16" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE7F4;" FontSize="18"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                <TextBlock
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Equipos" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock
                                FontSize="32" FontWeight="Bold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                Text="—" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                FontStyle="Italic"
                                Text="Próximamente" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- ══════════════════════════════════════════
                 Sección: Accesos rápidos
            ══════════════════════════════════════════ -->
            <StackPanel Grid.Row="4" Spacing="12">
                <TextBlock
                    FontSize="16" FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    Text="Accesos rápidos" />

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button x:Name="IrOperaciones" Click="IrOperaciones_Click"
                            Style="{StaticResource AccentButtonStyle}" IsEnabled="{Binding Converter={StaticResource AccessLevelConverter}, ConverterParameter=1}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE9F9;" FontSize="16" />
                            <TextBlock Text="Operaciones" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="IrMantenimiento" Click="IrMantenimiento_Click" IsEnabled="{Binding Converter={StaticResource AccessLevelConverter}, ConverterParameter=1}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE90F;" FontSize="16" />
                            <TextBlock Text="Mantenimiento" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="IrClientes" Click="IrClientes_Click" IsEnabled="{Binding Converter={StaticResource AccessLevelConverter}, ConverterParameter=1}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE716;" FontSize="16" />
                            <TextBlock Text="Clientes" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- ══════════════════════════════════════════
                 Sección: Área de tareas / actividad (placeholder)
            ══════════════════════════════════════════ -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <!-- Panel: Actividad reciente -->
                <Border
                    Grid.Column="0" Padding="20" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" MinHeight="220">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE823;" FontSize="16"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                <TextBlock
                                    FontSize="14" FontWeight="SemiBold"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                    Text="Actividad reciente" VerticalAlignment="Center" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    x:Name="RefreshActividad" Click="RefreshActividad_Click"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    Padding="6" ToolTipService.ToolTip="Actualizar" IsEnabled="{Binding Converter={StaticResource AccessLevelConverter}, ConverterParameter=1}">
                                <FontIcon Glyph="&#xE72C;" FontSize="14" />
                            </Button>
                        </Grid>

                        <!-- Lista de actividad -->
                        <Grid Grid.Row="2">

                            <!-- Overlay de carga -->
                            <ProgressRing IsActive="{x:Bind ViewModel.IsActividadLoading, Mode=OneWay}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Width="32" Height="32"
                                          Visibility="{x:Bind ViewModel.IsActividadLoading, Mode=OneWay}" />

                            <!-- Estado vacío -->
                            <StackPanel
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Spacing="8"
                                Visibility="{x:Bind ViewModel.IsActividadEmpty, Mode=OneWay}">
                                <FontIcon Glyph="&#xEA86;" FontSize="32"
                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                <TextBlock
                                    FontSize="13" HorizontalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    FontStyle="Italic"
                                    Text="Sin actividad reciente" />
                            </StackPanel>

                            <!-- Lista real -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="320">
                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.ActividadReciente, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="1" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:ActivityItem">
                                            <Border
                                                Padding="10,8" CornerRadius="6"
                                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                Margin="0,0,0,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="10" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Icono del módulo -->
                                                    <FontIcon Grid.Column="0"
                                                              Glyph="{x:Bind IconoGlyph}"
                                                              FontSize="14"
                                                              VerticalAlignment="Center"
                                                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />

                                                    <!-- Contenido -->
                                                    <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                                        <TextBlock
                                                            FontSize="13"
                                                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                            Text="{x:Bind Titulo}"
                                                            TextWrapping="NoWrap"
                                                            TextTrimming="CharacterEllipsis" />
                                                        <TextBlock
                                                            FontSize="11"
                                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                            Text="{x:Bind Origen}" />
                                                    </StackPanel>

                                                    <!-- Fecha -->
                                                    <TextBlock
                                                        Grid.Column="3"
                                                        FontSize="11"
                                                        VerticalAlignment="Center"
                                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                        Text="{x:Bind HoraLabel}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Panel: Tareas pendientes -->
                <Border
                    Grid.Column="2" Padding="20" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" MinHeight="220">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE762;" FontSize="16"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock
                                FontSize="14" FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                Text="Tareas pendientes" VerticalAlignment="Center" />
                        </StackPanel>
                        <Border
                            Padding="16" CornerRadius="6" MinHeight="140"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <StackPanel
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Spacing="8">
                                <FontIcon Glyph="&#xE762;" FontSize="32"
                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                <TextBlock
                                    FontSize="13" HorizontalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    FontStyle="Italic"
                                    Text="Sin tareas pendientes" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </ScrollViewer>
</Page>
