<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Advance_Control.Views.Items.Conciliacion.ConciliacionFacturaItemView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    mc:Ignorable="d">

    <Border
        Margin="0,0,15,0"
        Padding="12"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8">
        <StackPanel Spacing="10">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <StackPanel HorizontalAlignment="Center" Orientation="Vertical">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="{Binding Factura.FolioTitulo, ElementName=Root}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding Factura.FechaTexto, ElementName=Root}" />

                    </StackPanel>

                </Grid>
                <Grid Grid.Column="1">
                    <TextBlock
                        HorizontalAlignment="Center"
                        Text="{Binding Factura.EmisorReceptorTexto, ElementName=Root}"
                        TextWrapping="Wrap" />
                </Grid>
                <Grid Grid.Column="2">
                    <TextBlock
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding Factura.RfcTexto, ElementName=Root}" />
                </Grid>


            </Grid>


            <Border
                Margin="10"
                Padding="12"
                HorizontalAlignment="Stretch"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>


                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="Total" />
                        <TextBlock HorizontalAlignment="Center" Text="{Binding Factura.TotalTexto, ElementName=Root}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="Metodo PAgo" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding Factura.MetodoFormaPagoTexto, ElementName=Root}" />

                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="Saldo pendiente" />
                        <TextBlock HorizontalAlignment="Center" Text="{Binding Factura.SaldoPendienteTexto, ElementName=Root}" />
                    </StackPanel>


                </Grid>
            </Border>

            <StackPanel Spacing="2" />
        </StackPanel>
    </Border>
</UserControl>
