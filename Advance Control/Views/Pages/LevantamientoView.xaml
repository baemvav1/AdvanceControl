<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Advance_Control.Views.Pages.LevantamientoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Advance_Control.Models"
    x:Name="RootPage"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="HotspotButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2EFFFF00" />
            <Setter Property="BorderBrush" Value="Black" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Foreground" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Visibility" Value="Visible" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="600" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="1" Padding="0,22,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="70" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                Margin="0,0,10,0"
                Spacing="4">
                <TextBlock FontWeight="SemiBold" Text="Equipo" />
                <AutoSuggestBox
                    x:Name="EquipoAutoSuggestBox"
                    GotFocus="EquipoAutoSuggestBox_GotFocus"
                    PlaceholderText="Buscar equipo por identificador, marca..."
                    QueryIcon="Find"
                    SuggestionChosen="EquipoAutoSuggestBox_SuggestionChosen"
                    TextChanged="EquipoAutoSuggestBox_TextChanged" />
                <ProgressRing
                    Width="20"
                    Height="20"
                    HorizontalAlignment="Left"
                    IsActive="{Binding IsLoadingEquipos}"
                    Visibility="{Binding IsLoadingEquipos, Converter={StaticResource BoolToVisibilityConverter}}" />

            </StackPanel>

            <Grid Grid.Row="1">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Margin="0,0,0,10" Text="Introduccion Levantamiento" />
                    <TextBox
                        x:Name="ImputIntroduccion"
                        MaxHeight="200"
                        AcceptsReturn="True"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        TextWrapping="Wrap" />
                </StackPanel>


            </Grid>

            <ScrollViewer Grid.Row="2">
                <StackPanel Spacing="12">
                    <TreeView ItemsSource="{x:Bind ViewModel.CapturedTreeItems, Mode=OneWay}">
                        <TreeView.ItemTemplate>
                            <DataTemplate x:DataType="models:LevantamientoTreeItemModel">
                                <TreeViewItem IsExpanded="True" ItemsSource="{x:Bind Hijos}">
                                    <StackPanel Spacing="4">
                                        <!--  Fila principal: texto + botones  -->
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Etiqueta}" />
                                                <TextBlock
                                                    Opacity="0.78"
                                                    Text="{x:Bind DescripcionFalla}"
                                                    TextWrapping="Wrap"
                                                    Visibility="{x:Bind TieneFalla, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </StackPanel>
                                            <!--  Boton cargar imagen (solo nodos con falla)  -->
                                            <Button
                                                Padding="4"
                                                VerticalAlignment="Center"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="CargarImagenNodo_Click"
                                                Tag="{x:Bind}"
                                                ToolTipService.ToolTip="Cargar imagen"
                                                Visibility="{x:Bind TieneFalla, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <SymbolIcon Symbol="Camera" />
                                            </Button>
                                            <!--  Boton eliminar nodo  -->
                                            <Button
                                                Padding="4"
                                                VerticalAlignment="Center"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="EliminarCaptura_Click"
                                                Tag="{x:Bind Clave}"
                                                ToolTipService.ToolTip="Eliminar captura"
                                                Visibility="{x:Bind TieneFalla, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                            </Button>
                                        </StackPanel>
                                        <!--  Galeria de miniaturas (solo si tiene imagenes)  -->
                                        <ItemsRepeater ItemsSource="{x:Bind Imagenes, Mode=OneWay}">
                                            <ItemsRepeater.Layout>
                                                <StackLayout Orientation="Horizontal" Spacing="6" />
                                            </ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="models:LevantamientoImageItem">
                                                    <Grid
                                                        Width="80"
                                                        Height="80"
                                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                        CornerRadius="4">
                                                        <!--  Miniatura clickeable  -->
                                                        <Button
                                                            Padding="0"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Click="VerImagenNodo_Click"
                                                            Tag="{x:Bind}"
                                                            ToolTipService.ToolTip="{x:Bind Title}">
                                                            <Image
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Source="{x:Bind FilePath, Mode=OneWay}"
                                                                Stretch="UniformToFill" />
                                                        </Button>
                                                        <!--  Boton eliminar imagen overlay  -->
                                                        <Button
                                                            MinWidth="20"
                                                            MinHeight="20"
                                                            Margin="0,2,2,0"
                                                            Padding="4"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Background="#CC000000"
                                                            Click="EliminarImagenNodo_Click"
                                                            CornerRadius="10"
                                                            Tag="{x:Bind}"
                                                            ToolTipService.ToolTip="Eliminar imagen">
                                                            <SymbolIcon Foreground="White" Symbol="Cancel" />
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </StackPanel>
                                </TreeViewItem>
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="3">
                <StackPanel Margin="0,0,10,10">
                    <TextBlock Margin="0,0,0,10" Text="Conclusion Levantamiento" />
                    <TextBox
                        x:Name="ImputConclusion"
                        MaxHeight="200"
                        AcceptsReturn="True"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        TextWrapping="Wrap" />
                </StackPanel>


            </Grid>

            <Grid Grid.Row="4" Margin="0,0,10,30">
                <StackPanel
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="5">
                    <Button
                        x:Name="GuardarLevantamientoButton"
                        Click="GuardarLevantamiento_Click"
                        Content="Guardar levantamiento" />
                    <Button
                        x:Name="GenerarReporteButton"
                        Click="GenerarReporte_Click"
                        Content="Generar Reporte" />
                </StackPanel>
            </Grid>
        </Grid>



        <ScrollViewer
            Grid.Column="0"
            Padding="15"
            HorizontalScrollBarVisibility="Visible"
            HorizontalScrollMode="Enabled">
            <Viewbox
