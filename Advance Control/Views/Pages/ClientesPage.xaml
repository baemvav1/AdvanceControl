<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Advance_Control.Views.Pages.ClientesPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:converters="using:Advance_Control.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="using:Advance_Control.Views" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:LevelToBackgroundConverter x:Key="LevelToBackgroundConverter" />
        <converters:LevelToForegroundConverter x:Key="LevelToForegroundConverter" />
        <converters:BooleanToCornerRadiusConverter x:Key="BooleanToCornerRadiusConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BooleanToExpandTextConverter x:Key="BooleanToExpandTextConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <StackPanel
            Grid.Row="0" Margin="0,0,0,24" Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock
                    FontSize="32" FontWeight="Bold" Text="Clientes" />
                <Button
                    x:Name="Nuevo" VerticalAlignment="Center"
                    Click="NuevoButton_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTipService.ToolTip="Crear nuevo cliente">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Add" />
                        <TextBlock VerticalAlignment="Center" Text="Nuevo cliente" />
                    </StackPanel>
                </Button>
            </StackPanel>
            <TextBlock
                FontSize="16"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Gestión de clientes del sistema" />
        </StackPanel>

        <!--  Filtros  -->
        <StackPanel
            Grid.Row="1" Margin="0,0,0,8" Spacing="8">
            <Button
                x:Name="ToggleFiltrosButton"
                Click="ToggleFiltros_Click"
                Content="Filtros"/>
        </StackPanel>

        <!--  Panel de Filtros colapsable  -->
        <Grid
            Grid.Row="2"
            x:Name="Filtros"
            Visibility="Visible">
            <StackPanel Margin="0,0,0,16" Spacing="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox
                        Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" Header="Búsqueda"
                        PlaceholderText="Razón social o nombre comercial"
                        Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox
                        Grid.Row="0" Grid.Column="1" Margin="0,0,8,8" Header="RFC"
                        PlaceholderText="RFC del cliente"
                        Text="{x:Bind ViewModel.RfcFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox
                        Grid.Row="0" Grid.Column="2" Margin="0,0,8,8" Header="CURP"
                        PlaceholderText="CURP del cliente"
                        Text="{x:Bind ViewModel.CurpFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox
                        Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" Header="Notas"
                        PlaceholderText="Búsqueda en notas"
                        Text="{x:Bind ViewModel.NotasFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <NumberBox
                        Grid.Row="1" Grid.Column="1" Margin="0,0,8,8" Header="Prioridad"
                        Minimum="0" PlaceholderText="Prioridad exacta" SpinButtonPlacementMode="Inline" />

                    <StackPanel
                        Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" HorizontalAlignment="Right"
                        VerticalAlignment="Bottom" Orientation="Horizontal" Spacing="8">
                        <Button
                            Click="SearchButton_Click" Content="Buscar"
                            Style="{StaticResource AccentButtonStyle}"/>
                        <Button Click="ClearButton_Click" Content="Limpiar"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>

        <!--  Lista de clientes  -->
        <Grid Grid.Row="3">
            <!--  ItemsRepeater con ScrollViewer  -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Customers, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="0" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate xmlns:local="using:Advance_Control.Models" x:DataType="local:CustomerDto">
                            <Grid Margin="0,5,20,5">
                                <StackPanel Orientation="Vertical">
                                    <Grid
                                        Grid.Row="0" MinHeight="90" Padding="16"
                                        Background="{x:Bind Prioridad, Converter={StaticResource LevelToBackgroundConverter}}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1" 
                                        CornerRadius="{x:Bind Expand, Converter={StaticResource BooleanToCornerRadiusConverter}, ConverterParameter='8,8,0,0|8', Mode=OneWay}"
                                        Tapped="HeadGrid_Tapped"
                                        Tag="{x:Bind}"
                                        x:Name="Head">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!--  Información principal del cliente  -->
                                        <StackPanel Grid.Column="0" Spacing="6">
                                            <TextBlock
                                                FontSize="16" FontWeight="SemiBold"
                                                Foreground="{x:Bind Prioridad, Converter={StaticResource LevelToForegroundConverter}}"
                                                Text="{x:Bind RazonSocial}" />
                                            <TextBlock
                                                FontSize="14"
                                                Foreground="{x:Bind Prioridad, Converter={StaticResource LevelToForegroundConverter}}"
                                                Text="{x:Bind NombreComercial}" />
                                            <StackPanel Orientation="Horizontal" Spacing="20">
                                                <TextBlock FontSize="13" Foreground="{x:Bind Prioridad, Converter={StaticResource LevelToForegroundConverter}}">
                                                    <Run Text="RFC: " />
                                                    <Run FontWeight="SemiBold" Text="{x:Bind Rfc}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <!--  Botones de acción rápida  -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                            <Button
                                                Background="Transparent" BorderThickness="0"
                                                Click="EditClienteButton_Click"
                                                Tag="{x:Bind}"
                                                ToolTipService.ToolTip="Editar cliente">
                                                <SymbolIcon Symbol="Edit" />
                                            </Button>
                                            <Button
                                                Background="Transparent" BorderThickness="0"
                                                Click="DeleteClienteButton_Click"
                                                Tag="{x:Bind}"
                                                ToolTipService.ToolTip="Eliminar cliente">
                                                <SymbolIcon Symbol="Delete"
                                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                            </Button>
                                        </StackPanel>

                                        <!--  Botón para expandir/colapsar  -->
                                        <Button
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="ToggleExpandButton_Click"
                                            Tag="{x:Bind}"
                                            Content="{x:Bind Expand, Converter={StaticResource BooleanToExpandTextConverter}, Mode=OneWay}"/>
                                    </Grid>
                                    <Grid
                                        Grid.Row="1" 
                                        Background="{ThemeResource LayerFillColorDefaultBrush}" 
                                        CornerRadius="{x:Bind Expand, Converter={StaticResource BooleanToCornerRadiusConverter}, ConverterParameter='0,0,8,8|0', Mode=OneWay}"
                                        Visibility="{x:Bind Expand, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}"
                                        Padding="8"
                                        x:Name="Body">
                                        <Pivot>
                                            <!-- Información Fiscal y Legal -->
                                            <PivotItem Header="Fiscal y Legal">
                                                <Grid Padding="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    
                                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,4,8,0">
                                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Régimen Fiscal:" />
                                                        <TextBlock FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Text="{x:Bind RegimenFiscal}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                    
                                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,4,0,0">
                                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Uso CFDI:" />
                                                        <TextBlock FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Text="{x:Bind UsoCfdi}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                    
                                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,4,8,0">
                                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Estatus:" />
                                                        <TextBlock FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Text="{x:Bind Estatus}" />
                                                    </StackPanel>
                                                    
                                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,4,0,0">
                                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="ID Cliente:" />
                                                        <TextBlock FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Text="{x:Bind IdCliente}" />
                                                    </StackPanel>
                                                </Grid>
                                            </PivotItem>
                                            
                                            <!-- Información de Crédito -->
                                            <PivotItem Header="Crédito">
                                                <Grid Padding="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <StackPanel Grid.Column="0" Margin="0,4,8,0">
                                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Días de Crédito:" />
                                                        <TextBlock FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Text="{x:Bind DiasCredito}" />
                                                    </StackPanel>
                                                    
                                                    <StackPanel Grid.Column="1" Margin="0,4,0,0">
                                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Límite de Crédito:" />
                                                        <TextBlock FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Text="{x:Bind LimiteCredito}" />
                                                    </StackPanel>
                                                </Grid>
                                            </PivotItem>
                                            
                                            <!-- Notas -->
                                            <PivotItem Header="Notas">
                                                <StackPanel Padding="8">
                                                    <TextBlock FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Text="{x:Bind Notas}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </PivotItem>
                                            
                                            <!-- Información de Auditoría -->
                                            

                                            <PivotItem Header="Facturas">
                                                
                                            </PivotItem>

                                            <!-- Acciones eliminadas del Pivot; ahora están en el header de la tarjeta -->

                                            <!-- Contactos Relacionados -->
                                            <PivotItem Header="Contactos">
                                                <StackPanel Padding="8" Spacing="6">
                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                        <TextBlock
                                                            FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Text="Contactos Relacionados" />
                                                        <Button
                                                            x:Name="NuevoContacto" VerticalAlignment="Center" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderThickness="0"
                                                            Click="NuevoContacto_Click" ToolTipService.ToolTip="Agregar contacto" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            Tag="{x:Bind}">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <SymbolIcon Symbol="Add" />
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>

                                                    <!--  Loading indicator for contactos  -->
                                                    <ProgressRing
                                                        Width="20" Height="20" HorizontalAlignment="Left"
                                                        IsActive="{x:Bind IsLoadingContactos, Mode=OneWay}"
                                                        Visibility="{x:Bind IsLoadingContactos, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />

                                                    <!--  Lista de contactos  -->
                                                    <ItemsRepeater ItemsSource="{x:Bind Contactos, Mode=OneWay}">
                                                        <ItemsRepeater.Layout>
                                                            <StackLayout Spacing="4" />
                                                        </ItemsRepeater.Layout>
                                                        <ItemsRepeater.ItemTemplate>
                                                            <DataTemplate xmlns:models="using:Advance_Control.Models" x:DataType="models:ContactoDto">
                                                                <Border
                                                                    Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                                    BorderThickness="1" CornerRadius="4">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <StackPanel Grid.Column="0" Spacing="2">
                                                                            <TextBlock
                                                                                FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                                                Text="{x:Bind NombreCompleto}" />
                                                                            <TextBlock
                                                                                FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                                Text="{x:Bind Cargo}" />
                                                                            <TextBlock
                                                                                FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                                Text="{x:Bind Correo}"
                                                                                Visibility="{x:Bind Correo, Converter={StaticResource NullToVisibilityConverter}}" />
                                                                            <TextBlock
                                                                                FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                                Text="{x:Bind Telefono}"
                                                                                Visibility="{x:Bind Telefono, Converter={StaticResource NullToVisibilityConverter}}" />
                                                                        </StackPanel>
                                                                        <TextBlock
                                                                            Grid.Column="1" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="11"
                                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                                            <Run Text="ID: " />
                                                                            <Run Text="{x:Bind ContactoId}" />
                                                                        </TextBlock>
                                                                        <StackPanel
                                                                            Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal" Spacing="4">
                                                                            <Button
                                                                                AutomationProperties.Name="Eliminar contacto del cliente" Background="Transparent" BorderThickness="0" Click="DeleteContactoButton_Click"
                                                                                Tag="{x:Bind}"
                                                                                ToolTipService.ToolTip="Quitar contacto del cliente">
                                                                                <SymbolIcon Foreground="{ThemeResource TextFillColorPrimaryBrush}" Symbol="Delete" />
                                                                            </Button>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsRepeater.ItemTemplate>
                                                    </ItemsRepeater>

                                                    <!--  Mensaje cuando no hay contactos  -->
                                                    <TextBlock
                                                        FontSize="12" FontStyle="Italic" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="No hay contactos relacionados"
                                                        Visibility="{x:Bind ShowNoContactosMessage, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                                                </StackPanel>
                                            </PivotItem>
                                        </Pivot>
                                    </Grid>
                                </StackPanel>

                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

            <!--  Estado vacío  -->
            <StackPanel
                HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12"
                IsHitTestVisible="False"
                Visibility="{x:Bind ViewModel.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                <FontIcon Glyph="&#xE716;" FontSize="48"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock
                    FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Sin clientes" />
                <TextBlock
                    FontSize="13" HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="No se encontraron clientes con los filtros actuales." />
                <Button IsHitTestVisible="True"
                    HorizontalAlignment="Center" Click="ClearButton_Click"
                    Content="Limpiar filtros"/>
            </StackPanel>

            <!--  Loading overlay  -->
            <Grid
                Visibility="{x:Bind ViewModel.IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                <Rectangle Fill="{ThemeResource ApplicationPageBackgroundThemeBrush}" Opacity="0.7" />
                <ProgressRing
                    Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center"
                    IsActive="True" />
            </Grid>
        </Grid>
    </Grid>
</Page>
