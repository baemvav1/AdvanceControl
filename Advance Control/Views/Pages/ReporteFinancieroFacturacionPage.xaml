<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Advance_Control.Views.Pages.ReporteFinancieroFacturacionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:items="using:Advance_Control.Views.Items.RPTFacturasMovimientos"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Advance_Control.Models"
    mc:Ignorable="d">

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="5"
            Padding="10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="2"
            CornerRadius="8">
            <StackPanel Spacing="10">
                <TextBlock FontSize="10" Text="Filtros" />

                <Grid ColumnSpacing="12" RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="170" />
                    </Grid.ColumnDefinitions>

                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="0"
                        Spacing="4">
                        <TextBlock Text="RFC Receptor" />
                        <TextBox
                            PlaceholderText="RFC..."
                            Text="{x:Bind ViewModel.ReceptorRfcFiltro, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            TextChanged="Filtro_TextChanged" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="1"
                        Spacing="4">
                        <TextBlock Text="Referencia" />
                        <TextBox
                            PlaceholderText="Referencia..."
                            Text="{x:Bind ViewModel.ReferenciaFiltro, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            TextChanged="Filtro_TextChanged" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="2"
                        Spacing="4">
                        <TextBlock Text="Fecha Inicio" />
                        <CalendarDatePicker Date="{x:Bind ViewModel.FechaInicioFiltro, Mode=TwoWay}" DateChanged="FiltroFecha_DateChanged" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="3"
                        Spacing="4">
                        <TextBlock Text="Fecha Fin" />
                        <CalendarDatePicker Date="{x:Bind ViewModel.FechaFinFiltro, Mode=TwoWay}" DateChanged="FiltroFecha_DateChanged" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="4"
                        Spacing="4">
                        <TextBlock Text="Estado" />
                        <CheckBox Content="Solo finiquitadas" IsChecked="{x:Bind ViewModel.SoloFiniquitadas, Mode=TwoWay}" Checked="FiltroEstado_Changed" Unchecked="FiltroEstado_Changed" />
                        <CheckBox Content="No finiquitadas" IsChecked="{x:Bind ViewModel.NoFiniquitadas, Mode=TwoWay}" Checked="FiltroEstado_Changed" Unchecked="FiltroEstado_Changed" />
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Click="BtnLimpiar_Click" Content="Limpiar filtros" />
                    <Button Click="BtnGenerarReporte_Click" Content="Generar Reporte" IsEnabled="{x:Bind ViewModel.CanGenerarReporte, Mode=OneWay}" />
                    <ProgressRing
                        Width="24"
                        Height="24"
                        IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>

                <InfoBar
                    IsClosable="False"
                    IsOpen="{x:Bind ViewModel.ErrorMessage, Converter={StaticResource NullToBoolConverter}, Mode=OneWay}"
                    Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    Severity="Error" />

                <InfoBar
                    IsClosable="False"
                    IsOpen="{x:Bind ViewModel.SuccessMessage, Converter={StaticResource NullToBoolConverter}, Mode=OneWay}"
                    Message="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"
                    Severity="Success" />

                <StackPanel
                    Grid.Column="0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="5">
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.ResumenCabecerasTexto, Mode=OneWay}" />
                    <TextBlock Text="Total Facturado:" />
                    <TextBlock HorizontalAlignment="Right" Text="{x:Bind ViewModel.TotalFacturadoTexto, Mode=OneWay}" />
                    <TextBlock Text="Total Finiquitado:" />
                    <TextBlock HorizontalAlignment="Right" Text="{x:Bind ViewModel.TotalAbonadoTexto, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>
        </Border>
        <Border
            Grid.Row="1"
            Margin="5,0,5,5"
            Padding="10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="2"
            CornerRadius="8">
            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="2">
                    <TextBlock FontWeight="SemiBold" Text="Facturas y movimientos" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.ResumenDetalleTexto, Mode=OneWay}" />
                </StackPanel>

                <ScrollViewer Grid.Row="1">
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.ListadoItems, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="10" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:ReporteFinancieroFacturacionListadoItemDto">
                                <Grid>
                                    <items:ReporteFacturacionCabeceraItemView Cabecera="{Binding Cabecera}" Visibility="{Binding EsCabecera, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <items:ReporteFacturacionDetalleItemView
                                        Margin="20,0,0,0"
                                        Detalle="{Binding Detalle}"
                                        Visibility="{Binding EsDetalle, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
