<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Advance_Control.Views.Windows.OperacionVisorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Advance_Control.Converters"
    xmlns:models="using:Advance_Control.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <converters:CurrencyConverter x:Key="CurrencyConverter" />
            <converters:BooleanToSystemColorBrushConverter x:Key="BoolToColorBrushConverter" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Barra de título -->
        <Grid
            Grid.Row="0"
            Padding="16,0"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal" Spacing="12">
                <SymbolIcon Symbol="Document" />
                <TextBlock
                    FontSize="15"
                    FontWeight="SemiBold"
                    Text="{x:Bind Operacion.Identificador, Mode=OneWay}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="13"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind Operacion.RazonSocial, Mode=OneWay}" />
                <Border
                    Padding="6,2"
                    VerticalAlignment="Center"
                    Background="#152DA44E"
                    BorderBrush="#2DA44E"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{Binding Operacion.IsEditable, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock FontSize="11" Foreground="#2DA44E" Text="● Abierta" />
                </Border>
                <Border
                    Padding="6,2"
                    VerticalAlignment="Center"
                    Background="#15808080"
                    BorderBrush="#808080"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{Binding Operacion.IsFinalized, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock FontSize="11" Foreground="#808080" Text="✓ Finalizada" />
                </Border>
            </StackPanel>
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="{ThemeResource SystemAccentColor}"
                Text="{Binding Operacion.Monto, Converter={StaticResource CurrencyConverter}}" />
        </Grid>

        <!-- Contenido en 3 paneles -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="220" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="260" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Border Grid.Column="3" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

            <!-- ════ PANEL IZQUIERDO – Información + TabView ════ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" MaxHeight="260" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Información de la operación -->
                <ScrollViewer Grid.Row="0" Padding="12" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="13" FontWeight="SemiBold" Text="Información" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,2,8,2" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Cliente:" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,2" FontSize="12" Text="{x:Bind Operacion.RazonSocial, Mode=OneWay}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind Operacion.RazonSocial, Mode=OneWay}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,2,8,2" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Equipo:" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,2" FontSize="12" Text="{x:Bind Operacion.Identificador, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,2,8,2" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Atiende:" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,2" FontSize="12" Text="{x:Bind Operacion.Atiende, Mode=OneWay}" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,2,8,2" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Inicio:" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,2" FontSize="12" Text="{x:Bind Operacion.FechaInicioCorta, Mode=OneWay}" />
                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,2,8,2" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Final:" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,2" FontSize="12" Text="{x:Bind Operacion.StatusText, Mode=OneWay}" />
                            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,2,8,2" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Monto:" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,2" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemAccentColor}" Text="{Binding Operacion.Monto, Converter={StaticResource CurrencyConverter}}" />
                            <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,4,8,2" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Nota:" Visibility="{Binding Operacion.Nota, Converter={StaticResource NullToVisibilityConverter}}" />
                            <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,4,0,2" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind Operacion.Nota, Mode=OneWay}" TextWrapping="Wrap" Visibility="{Binding Operacion.Nota, Converter={StaticResource NullToVisibilityConverter}}" />
                        </Grid>
                        <!-- Indicadores de progreso del check -->
                        <StackPanel
                            Margin="0,4,0,0"
                            Orientation="Horizontal"
                            Spacing="4"
                            Visibility="{Binding Operacion.TieneCheck, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Width="10" Height="10" CornerRadius="5" Background="{Binding Operacion.CkCotizacionGenerada, Converter={StaticResource BoolToColorBrushConverter}, ConverterParameter='#22C55E|#6B7280'}">
                                <ToolTipService.ToolTip><ToolTip Content="Cotización generada" /></ToolTipService.ToolTip>
                            </Border>
                            <Border Width="10" Height="10" CornerRadius="5" Background="{Binding Operacion.CkCotizacionEnviada, Converter={StaticResource BoolToColorBrushConverter}, ConverterParameter='#22C55E|#6B7280'}">
                                <ToolTipService.ToolTip><ToolTip Content="Cotización enviada" /></ToolTipService.ToolTip>
                            </Border>
                            <Border Width="10" Height="10" CornerRadius="5" Background="{Binding Operacion.CkReporteGenerado, Converter={StaticResource BoolToColorBrushConverter}, ConverterParameter='#22C55E|#6B7280'}">
                                <ToolTipService.ToolTip><ToolTip Content="Reporte generado" /></ToolTipService.ToolTip>
                            </Border>
                            <Border Width="10" Height="10" CornerRadius="5" Background="{Binding Operacion.CkReporteEnviado, Converter={StaticResource BoolToColorBrushConverter}, ConverterParameter='#22C55E|#6B7280'}">
                                <ToolTipService.ToolTip><ToolTip Content="Reporte enviado" /></ToolTipService.ToolTip>
                            </Border>
                            <Border Width="10" Height="10" Margin="4,0,0,0" CornerRadius="5" Background="{Binding Operacion.CkPrefacturaCargada, Converter={StaticResource BoolToColorBrushConverter}, ConverterParameter='#22C55E|#6B7280'}">
                                <ToolTipService.ToolTip><ToolTip Content="Prefactura cargada" /></ToolTipService.ToolTip>
                            </Border>
                            <Border Width="10" Height="10" CornerRadius="5" Background="{Binding Operacion.CkHojaServicioCargada, Converter={StaticResource BoolToColorBrushConverter}, ConverterParameter='#22C55E|#6B7280'}">
                                <ToolTipService.ToolTip><ToolTip Content="Hoja servicio" /></ToolTipService.ToolTip>
                            </Border>
                            <Border Width="10" Height="10" CornerRadius="5" Background="{Binding Operacion.CkOrdenCompraCargada, Converter={StaticResource BoolToColorBrushConverter}, ConverterParameter='#22C55E|#6B7280'}">
                                <ToolTipService.ToolTip><ToolTip Content="Orden de compra" /></ToolTipService.ToolTip>
                            </Border>
                            <Border Width="10" Height="10" CornerRadius="5" Background="{Binding Operacion.CkFacturaCargada, Converter={StaticResource BoolToColorBrushConverter}, ConverterParameter='#22C55E|#6B7280'}">
                                <ToolTipService.ToolTip><ToolTip Content="Factura cargada" /></ToolTipService.ToolTip>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- TabView Acciones / Documentos -->
                <TabView
                    Grid.Row="1"
                    Padding="0"
                    IsAddTabButtonVisible="False"
                    TabWidthMode="Equal">

                    <!-- Tab Acciones -->
                    <TabViewItem Header="Acciones" IsClosable="False">
                        <ScrollViewer Padding="12" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="8">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="Documentos PDF" />
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button
                                            Background="{ThemeResource SystemAccentColor}"
                                            Click="GenerarCotizacionButton_Click"
                                            ToolTipService.ToolTip="Generar cotización PDF">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <SymbolIcon Symbol="Document" />
                                                <TextBlock Text="Cotización" />
                                            </StackPanel>
                                        </Button>
                                        <Button
                                            Padding="8"
                                            Click="AbrirCotizacionPdfButton_Click"
                                            ToolTipService.ToolTip="Abrir cotización PDF"
                                            Visibility="{Binding Operacion.CotizacionPdfPath, Converter={StaticResource NullToVisibilityConverter}}">
                                            <FontIcon FontSize="14" Glyph="&#xEA90;" />
                                        </Button>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button
                                            Background="{ThemeResource SystemAccentColor}"
                                            Click="GenerarReporteButton_Click"
                                            ToolTipService.ToolTip="Generar reporte PDF">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <SymbolIcon Symbol="Pictures" />
                                                <TextBlock Text="Reporte" />
                                            </StackPanel>
                                        </Button>
                                        <Button
                                            Padding="8"
                                            Click="AbrirReportePdfButton_Click"
                                            ToolTipService.ToolTip="Abrir reporte PDF"
                                            Visibility="{Binding Operacion.ReportePdfPath, Converter={StaticResource NullToVisibilityConverter}}">
                                            <FontIcon FontSize="14" Glyph="&#xEA90;" />
                                        </Button>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Margin="0,8,0,0" FontSize="12" FontWeight="SemiBold" Text="Editar" />
                                <Button
                                    Background="{ThemeResource SystemAccentColor}"
                                    Click="EditOperacionButton_Click"
                                    IsEnabled="{x:Bind Operacion.IsEditable, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <SymbolIcon Symbol="Edit" />
                                        <TextBlock Text="Editar Operación" />
                                    </StackPanel>
                                </Button>

                                <TextBlock
                                    Margin="0,8,0,0"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Text="Reabrir"
                                    Visibility="{Binding Operacion.IsFinalized, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button
                                    Click="ReabrirOperacionButton_Click"
                                    Visibility="{Binding Operacion.IsFinalized, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <SymbolIcon Symbol="Refresh" />
                                        <TextBlock Text="Reabrir Operación" />
                                    </StackPanel>
                                </Button>

                                <TextBlock Margin="0,8,0,0" FontSize="12" FontWeight="SemiBold" Text="Eliminar" />
                                <Button
                                    Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                                    Click="DeleteOperacionButton_Click"
                                    IsEnabled="{x:Bind Operacion.IsEditable, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <SymbolIcon Symbol="Delete" />
                                        <TextBlock Text="Eliminar Operación" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </TabViewItem>

                    <!-- Tab Documentos -->
                    <TabViewItem Header="Documentos" IsClosable="False">
                        <ScrollViewer Padding="12" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="Cargar imágenes" />
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button
                                            Background="{ThemeResource SystemAccentColor}"
                                            Click="UploadPrefacturaButton_Click"
                                            IsEnabled="{x:Bind Operacion.IsEditable, Mode=OneWay}"
                                            ToolTipService.ToolTip="Cargar prefactura">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon FontSize="14" Glyph="&#xE898;" />
                                                <TextBlock Text="Prefactura" />
                                            </StackPanel>
                                        </Button>
                                        <Button
                                            Background="{ThemeResource SystemAccentColor}"
                                            Click="UploadHojaServicioButton_Click"
                                            IsEnabled="{x:Bind Operacion.IsEditable, Mode=OneWay}"
                                            ToolTipService.ToolTip="Cargar hoja de servicio">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon FontSize="14" Glyph="&#xE898;" />
                                                <TextBlock Text="Hoja Servicio" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button
                                            Background="{ThemeResource SystemAccentColor}"
                                            Click="UploadOrdenCompraButton_Click"
                                            IsEnabled="{x:Bind Operacion.IsEditable, Mode=OneWay}"
                                            ToolTipService.ToolTip="Cargar orden de compra">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon FontSize="14" Glyph="&#xE898;" />
                                                <TextBlock Text="Orden Compra" />
                                            </StackPanel>
                                        </Button>
                                        <Button
                                            Style="{StaticResource AccentButtonStyle}"
                                            Click="UploadFacturaButton_Click"
                                            IsEnabled="{x:Bind Operacion.IsEditable, Mode=OneWay}"
                                            ToolTipService.ToolTip="Cargar factura PDF (finaliza la operación)">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <SymbolIcon Symbol="Attach" />
                                                <TextBlock Text="Factura" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>

                                <Button
                                    Background="{ThemeResource SystemAccentColor}"
                                    Click="VerFacturaButton_Click"
                                    ToolTipService.ToolTip="Abrir factura PDF"
                                    Visibility="{Binding Operacion.HasFactura, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <SymbolIcon Symbol="OpenFile" />
                                        <TextBlock Text="Ver Factura" />
                                    </StackPanel>
                                </Button>

                                <!-- Hojas de servicio -->
                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="Hojas de servicio:" Visibility="{Binding Operacion.HasHojaServicio, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <ItemsRepeater
                                    ItemsSource="{x:Bind Operacion.ImagenesHojaServicio, Mode=OneWay}"
                                    Visibility="{Binding Operacion.HasHojaServicio, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Horizontal" Spacing="6" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:OperacionImageDto">
                                            <Grid Width="80" Height="80" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4">
                                                <Button Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" BorderThickness="0" Click="ViewOperacionImageButton_Click" Tag="{x:Bind}" ToolTipService.ToolTip="Ver imagen">
                                                    <Image Source="{x:Bind Url, Mode=OneWay}" Stretch="UniformToFill" />
                                                </Button>
                                                <Button MinWidth="18" MinHeight="18" Margin="0,2,2,0" Padding="3" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#CC000000" Click="DeleteOperacionImageButton_Click" CornerRadius="9" Tag="{x:Bind}" ToolTipService.ToolTip="Eliminar imagen">
                                                    <SymbolIcon Foreground="White" Symbol="Cancel" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>

                                <!-- Prefacturas -->
                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="Prefacturas:" Visibility="{Binding Operacion.HasPrefactura, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <ItemsRepeater
                                    ItemsSource="{x:Bind Operacion.ImagenesPrefactura, Mode=OneWay}"
                                    Visibility="{Binding Operacion.HasPrefactura, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Horizontal" Spacing="6" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:OperacionImageDto">
                                            <Grid Width="80" Height="80" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4">
                                                <Button Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" BorderThickness="0" Click="ViewOperacionImageButton_Click" Tag="{x:Bind}" ToolTipService.ToolTip="Ver imagen">
                                                    <Image Source="{x:Bind Url, Mode=OneWay}" Stretch="UniformToFill" />
                                                </Button>
                                                <Button MinWidth="18" MinHeight="18" Margin="0,2,2,0" Padding="3" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#CC000000" Click="DeleteOperacionImageButton_Click" CornerRadius="9" Tag="{x:Bind}" ToolTipService.ToolTip="Eliminar imagen">
                                                    <SymbolIcon Foreground="White" Symbol="Cancel" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>

                                <!-- Órdenes de compra -->
                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="Órdenes de compra:" Visibility="{Binding Operacion.HasOrdenCompra, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <ItemsRepeater
                                    ItemsSource="{x:Bind Operacion.ImagenesOrdenCompra, Mode=OneWay}"
                                    Visibility="{Binding Operacion.HasOrdenCompra, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Horizontal" Spacing="6" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:OperacionImageDto">
                                            <Grid Width="80" Height="80" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4">
                                                <Button Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" BorderThickness="0" Click="ViewOperacionImageButton_Click" Tag="{x:Bind}" ToolTipService.ToolTip="Ver imagen">
                                                    <Image Source="{x:Bind Url, Mode=OneWay}" Stretch="UniformToFill" />
                                                </Button>
                                                <Button MinWidth="18" MinHeight="18" Margin="0,2,2,0" Padding="3" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#CC000000" Click="DeleteOperacionImageButton_Click" CornerRadius="9" Tag="{x:Bind}" ToolTipService.ToolTip="Eliminar imagen">
                                                    <SymbolIcon Foreground="White" Symbol="Cancel" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </ScrollViewer>
                    </TabViewItem>
                </TabView>
            </Grid>

            <!-- ════ PANEL CENTRAL – Cargos ════ -->
            <Grid Grid.Column="2" Padding="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Margin="0,0,0,8" FontSize="13" FontWeight="SemiBold" Text="Cargos" />

                <!-- Botón agregar -->
                <StackPanel Grid.Row="1" Margin="0,0,0,6" Orientation="Horizontal" Spacing="8">
                    <Button
                        Click="AddCargoButton_Click"
                        IsEnabled="{x:Bind Operacion.IsEditable, Mode=OneWay}"
                        Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <SymbolIcon Symbol="Add" />
                            <TextBlock Text="Agregar Cargo" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Tabla de cargos -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Encabezado -->
                        <Grid Grid.Row="0" Margin="0,0,0,2" Padding="8,4" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="65" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="44" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontSize="12" FontWeight="SemiBold" Text="Tipo" />
                            <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold" Text="Detalle" />
                            <TextBlock Grid.Column="2" FontSize="12" FontWeight="SemiBold" Text="Cant." />
                            <TextBlock Grid.Column="3" FontSize="12" FontWeight="SemiBold" Text="Unitario" />
                            <TextBlock Grid.Column="4" FontSize="12" FontWeight="SemiBold" Text="Monto" />
                            <TextBlock Grid.Column="5" FontSize="12" FontWeight="SemiBold" Text="Nota" />
                            <TextBlock Grid.Column="6" FontSize="12" FontWeight="SemiBold" Text="Proveedor" />
                            <TextBlock Grid.Column="7" HorizontalAlignment="Center" FontSize="12" FontWeight="SemiBold" Text="Sel." ToolTipService.ToolTip="Seleccionar" />
                        </Grid>

                        <!-- Indicador de carga + Sin cargos (comparten fila, son mutuamente exclusivos) -->
                        <StackPanel Grid.Row="1"
                            Margin="0,24"
                            HorizontalAlignment="Center"
                            Spacing="8"
                            Visibility="{Binding Operacion.IsLoadingCargos, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ProgressRing IsActive="True" Width="28" Height="28" HorizontalAlignment="Center" />
                            <TextBlock
                                FontSize="12"
                                FontStyle="Italic"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Cargando cargos..." />
                        </StackPanel>

                        <!-- Sin cargos registrados -->
                        <StackPanel Grid.Row="1"
                            Margin="0,24"
                            HorizontalAlignment="Center"
                            Spacing="6"
                            Visibility="{Binding Operacion.ShowNoCargosMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <FontIcon FontSize="24" Glyph="&#xE8F4;" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <TextBlock
                                FontSize="12"
                                FontStyle="Italic"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Text="Sin cargos registrados" />
                        </StackPanel>

                        <!-- Filas de cargos -->
                        <ItemsRepeater Grid.Row="2" ItemsSource="{x:Bind Operacion.Cargos, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="2" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:CargoDto">
                                    <StackPanel
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1"
                                        Tapped="CargoRow_Tapped">
                                        <Grid Padding="8,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="65" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="44" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" Text="{x:Bind TipoCargo, Mode=OneWay}" TextTrimming="CharacterEllipsis" />

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind DetalleLinea1, Mode=OneWay}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind DetalleLinea1, Mode=OneWay}" />
                                                <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind DetalleLinea2, Mode=OneWay}" TextTrimming="CharacterEllipsis" Visibility="{Binding TieneSubdetalle, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind DetalleLinea3, Mode=OneWay}" TextTrimming="CharacterEllipsis" Visibility="{Binding TieneSubdetalle, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            </StackPanel>

                                            <!-- Cantidad -->
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="12" Text="{x:Bind Cantidad, Mode=OneWay}" Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}" />
                                            <TextBox Grid.Column="2" MinHeight="28" Margin="0,0,4,0" Padding="4,2" VerticalAlignment="Center" FontSize="12" KeyDown="CargoField_KeyDown" Tag="{x:Bind}" Text="{x:Bind Cantidad, Mode=TwoWay}" Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                            <!-- Unitario -->
                                            <TextBlock Grid.Column="3" VerticalAlignment="Center" FontSize="12" Text="{Binding Unitario, Converter={StaticResource CurrencyConverter}}" Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}" />
                                            <TextBox Grid.Column="3" MinHeight="28" Margin="0,0,4,0" Padding="4,2" VerticalAlignment="Center" FontSize="12" KeyDown="CargoField_KeyDown" Tag="{x:Bind}" Text="{x:Bind Unitario, Mode=TwoWay}" Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                            <!-- Monto -->
                                            <TextBlock Grid.Column="4" VerticalAlignment="Center" FontSize="12" Text="{Binding Monto, Converter={StaticResource CurrencyConverter}}" />

                                            <!-- Nota -->
                                            <TextBlock Grid.Column="5" VerticalAlignment="Center" FontSize="12" Text="{x:Bind Nota, Mode=OneWay}" TextTrimming="CharacterEllipsis" Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}" />
                                            <TextBox Grid.Column="5" MinHeight="28" Margin="0,0,4,0" Padding="4,2" VerticalAlignment="Center" FontSize="12" KeyDown="CargoField_KeyDown" Tag="{x:Bind}" Text="{x:Bind Nota, Mode=TwoWay}" Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                            <!-- Proveedor -->
                                            <TextBlock Grid.Column="6" VerticalAlignment="Center" FontSize="12" Text="{x:Bind Proveedor, Mode=OneWay}" TextTrimming="CharacterEllipsis" />

                                            <CheckBox
                                                Grid.Column="7"
                                                MinWidth="0"
                                                Padding="0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Checked="CargoCheckBox_Checked"
                                                IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                Tag="{x:Bind}" />
                                        </Grid>

                                        <!-- Galería de imágenes del cargo -->
                                        <Grid
                                            Padding="8,4"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            Visibility="{Binding ShouldShowGallery, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Text="Imágenes:" />
                                            <ItemsRepeater Grid.Row="1" ItemsSource="{x:Bind Images, Mode=OneWay}">
                                                <ItemsRepeater.Layout>
                                                    <StackLayout Orientation="Horizontal" Spacing="8" />
                                                </ItemsRepeater.Layout>
                                                <ItemsRepeater.ItemTemplate>
                                                    <DataTemplate x:DataType="models:CargoImageDto">
                                                        <Grid Width="90" Height="90" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4">
                                                            <Image HorizontalAlignment="Center" VerticalAlignment="Center" Source="{Binding Url}" Stretch="UniformToFill" />
                                                            <Button MinWidth="18" MinHeight="18" Margin="0,2,2,0" Padding="3" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#CC000000" Click="DeleteCargoImageButton_Click" CornerRadius="9" Tag="{x:Bind}" ToolTipService.ToolTip="Eliminar imagen">
                                                                <SymbolIcon Foreground="White" Symbol="Cancel" />
                                                            </Button>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsRepeater.ItemTemplate>
                                            </ItemsRepeater>
                                        </Grid>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </Grid>
                </ScrollViewer>

                <!-- Barra de acciones para cargos seleccionados -->
                <StackPanel
                    Grid.Row="3"
                    Margin="0,8,0,0"
                    Padding="8"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="4"
                    Orientation="Horizontal"
                    Spacing="6">
                    <TextBlock Margin="0,0,4,0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Text="Selección:" />
                    <Button Click="UploadSelectedCargoImageButton_Click" ToolTipService.ToolTip="Cargar imagen al cargo seleccionado">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <SymbolIcon Symbol="Camera" />
                            <TextBlock Text="Imagen" />
                        </StackPanel>
                    </Button>
                    <Button Click="EditSelectedCargoButton_Click" ToolTipService.ToolTip="Editar cargo seleccionado">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <SymbolIcon Symbol="Edit" />
                            <TextBlock Text="Editar" />
                        </StackPanel>
                    </Button>
                    <Button Click="DeleteSelectedCargosButton_Click" ToolTipService.ToolTip="Eliminar cargos seleccionados">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <SymbolIcon Symbol="Delete" />
                            <TextBlock Text="Eliminar" />
                        </StackPanel>
                    </Button>
                    <Button Click="ViewSelectedRefaccionButton_Click" ToolTipService.ToolTip="Ver refacción seleccionada">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <SymbolIcon Symbol="View" />
                            <TextBlock Text="Refacción" />
                        </StackPanel>
                    </Button>
                    <Button Click="ExpandSelectedGalleryButton_Click" ToolTipService.ToolTip="Ver imágenes del cargo seleccionado">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <SymbolIcon Symbol="Pictures" />
                            <TextBlock Text="Imágenes" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Total -->
                <Border
                    Grid.Row="4"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Right"
                    Padding="12,6"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Text="Total:" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource SystemAccentColor}"
                            Text="{Binding Operacion.TotalMonto, Converter={StaticResource CurrencyConverter}}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ════ PANEL DERECHO – Tareas ════ -->
            <Grid Grid.Column="4" Padding="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Margin="0,0,0,12" FontSize="13" FontWeight="SemiBold" Text="Tareas" />

                <!-- Progreso -->
                <StackPanel
                    Grid.Row="1"
                    Margin="0,0,0,16"
                    Spacing="6"
                    Visibility="{Binding Operacion.TieneCheck, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ProgressBar Maximum="8" Value="{x:Bind Operacion.CkStepsCompletados, Mode=OneWay}" />
                    <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <Run FontWeight="SemiBold" Text="{x:Bind Operacion.CkStepsCompletados, Mode=OneWay}" />
                        <Run Text="/ 8 pasos completados" />
                    </TextBlock>
                </StackPanel>

                <!-- Lista de pasos -->
                <ItemsRepeater
                    Grid.Row="2"
                    ItemsSource="{x:Bind Operacion.CkPasos, Mode=OneWay}"
                    Visibility="{Binding Operacion.TieneCheck, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="12" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:CheckPasoItem">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="{Binding Completado, Converter={StaticResource BoolToColorBrushConverter}, ConverterParameter='#22C55E|#808080'}"
                                    Glyph="{x:Bind Glyph}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="{Binding Completado, Converter={StaticResource BoolToColorBrushConverter}, ConverterParameter='#22C55E|#808080'}"
                                    Text="{x:Bind Nombre}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- Cargando tareas -->
                <StackPanel
                    Grid.Row="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8"
                    Visibility="{Binding Operacion.IsLoadingCheck, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ProgressRing IsActive="True" Width="28" Height="28" HorizontalAlignment="Center" />
                    <TextBlock
                        FontSize="12"
                        FontStyle="Italic"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Cargando tareas..." />
                </StackPanel>

                <!-- Sin tareas registradas -->
                <TextBlock
                    Grid.Row="2"
                    FontSize="12"
                    FontStyle="Italic"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="Sin tareas registradas"
                    Visibility="{Binding Operacion.ShowNoCheckMessage, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
        </Grid>
    </Grid>
</Window>
