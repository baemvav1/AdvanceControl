<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Advance_Control.Views.Items.MovimientoItemView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Advance_Control.Models"
    mc:Ignorable="d">

    <Border
        Margin="0,0,0,10"
        Padding="14"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="2"
        CornerRadius="6">
        <StackPanel Spacing="12">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="10"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <StackPanel Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="{Binding FechaTexto}" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding GrupoId}" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock
                        FontWeight="SemiBold"
                        Text="{Binding TipoTitulo}"
                        TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Descripcion}" TextWrapping="Wrap" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding ReferenciaTexto}" />
                </StackPanel>
            </Grid>

            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="10"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <StackPanel Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="Abono" />
                        <TextBlock FontSize="16" Text="{Binding AbonoTexto}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="10"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <StackPanel Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="Cargo" />
                        <TextBlock FontSize="16" Text="{Binding CargoTexto}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Padding="10"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <StackPanel Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="Saldo resultante" />
                        <TextBlock FontSize="16" Text="{Binding SaldoTexto}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border
                Padding="10"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6">
                <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="Metadatos del movimiento" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding MetadatosTexto}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="{Binding RelacionadosResumen}" />
                <ListView
                    Background="Transparent"
                    BorderThickness="0"
                    ItemsSource="{Binding MovimientosRelacionados}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:EstadoCuentaMovimientoRelacionadoDetalleDto">
                            <Border
                                Margin="0,0,0,6"
                                Padding="10"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                                <StackPanel Spacing="8">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Titulo}" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{Binding OrdenTexto}" />
                                        </StackPanel>

                                        <Border
                                            Grid.Column="1"
                                            Padding="10,4"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{Binding TipoRelacionTexto}" />
                                        </Border>
                                    </Grid>

                                    <TextBlock Text="{Binding Descripcion}" TextWrapping="Wrap" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding RfcTexto}" />

                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border
                                            Grid.Column="0"
                                            Padding="8"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                            <StackPanel Spacing="4">
                                                <TextBlock FontWeight="SemiBold" Text="Monto relacionado" />
                                                <TextBlock Text="{Binding MontoTexto}" />
                                            </StackPanel>
                                        </Border>

                                        <Border
                                            Grid.Column="1"
                                            Padding="8"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                            <StackPanel Spacing="4">
                                                <TextBlock FontWeight="SemiBold" Text="Saldo posterior" />
                                                <TextBlock Text="{Binding SaldoTexto}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
