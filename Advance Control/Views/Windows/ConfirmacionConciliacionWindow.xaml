<Window
    x:Class="Advance_Control.Views.Windows.ConfirmacionConciliacionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dialogs="using:Advance_Control.Views.Dialogs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Barra de filtro -->
        <Border
            Grid.Row="0"
            Padding="20,14,20,10"
            BorderThickness="0,0,0,1"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <TextBox
                x:Name="TxtFiltroMetadato"
                PlaceholderText="Filtrar por metadato del movimiento..."
                TextChanged="TxtFiltroMetadato_TextChanged"
                Width="420"
                HorizontalAlignment="Left"/>
        </Border>

        <!-- Contenido: UserControl con la tabla de propuestas -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,12,20,0">
            <dialogs:ConfirmacionConciliacionUserControl x:Name="ControlConfirmacion"/>
        </ScrollViewer>

        <!-- Footer con botones -->
        <Border
            Grid.Row="2"
            BorderThickness="0,1,0,0"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    x:Name="TxtResumen"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button
                        x:Name="BtnCancelar"
                        Content="Cancelar"
                        Click="BtnCancelar_Click"/>
                    <Button
                        x:Name="BtnConfirmar"
                        Content="Confirmar seleccionadas"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="BtnConfirmar_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
